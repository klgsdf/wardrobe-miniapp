.settings-page {
  min-height: 100vh;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
}

.header-bar {
  position: relative;
}

.back-icon {
  width: 18px;
  height: 18px;
}

.settings-group-title {
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  margin-bottom: 8px;
  padding-left: 4px;
  display: block;
}

.settings-item {
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0;
}

.settings-icon-box {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.settings-icon {
  width: 18px;
  height: 18px;
}

.settings-arrow {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.about-icon-box {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.form-input {
  width: 100%;
  padding: 10px 14px;
  border-radius: 10px;
  background: var(--bg);
  box-shadow: inset 3px 3px 8px var(--shadow-inset-dark), inset -3px -3px 8px var(--shadow-inset-light);
  font-size: 14px;
  color: var(--text-primary);
  box-sizing: border-box;
}

.bottom-sheet {
  background: var(--card-bg, var(--bg));
  border-radius: 28px;
  padding: 20px 16px 40px 16px;
  position: relative;
  z-index: 10;
  width: 92vw;
  max-width: 560px;
  margin: 0 auto calc(24px + env(safe-area-inset-bottom)) auto;
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    0 -12px 48px var(--shadow-dark),
    0 -4px 16px var(--shadow-dark),
    0 -1px 4px var(--shadow-dark),
    inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

/* ===== Background Preview Thumb ===== */
.bg-preview-thumb {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  flex-shrink: 0;
  box-shadow: inset 2px 2px 4px rgba(0,0,0,0.1);
  overflow: hidden;
  position: relative;
}

.bg-preview-img {
  width: 100%;
  height: 100%;
  display: block;
}

.bg-preview-placeholder {
  width: 100%;
  height: 100%;
  background: var(--accent-soft);
}

/* ===== Theme Cards Grid ===== */
.theme-cards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding-bottom: 8px;
}

.theme-card-item {
  border-radius: 16px;
  padding: 16px 14px;
  position: relative;
  transition: transform 150ms ease;
  box-shadow: 4px 4px 12px rgba(0,0,0,0.08), -2px -2px 8px rgba(255,255,255,0.6);
}

.theme-card-item:active {
  transform: scale(0.97);
}

.theme-card-active {
  box-shadow: 0 0 0 2px var(--accent), 4px 4px 12px rgba(0,0,0,0.08);
}

.theme-card-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.theme-color-dot {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  margin-bottom: 10px;
}

.theme-card-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.theme-card-desc {
  font-size: 11px;
  color: var(--text-muted);
  line-height: 1.4;
  margin-bottom: 8px;
}

.theme-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.theme-keyword-tag {
  font-size: 9px;
  padding: 2px 8px;
  border-radius: 9999px;
  background: rgba(255,255,255,0.5);
  color: var(--text-secondary);
  border: 1px solid rgba(0,0,0,0.06);
}

.theme-check {
  position: absolute;
  top: 10px;
  right: 10px;
}

.theme-check-inner {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== Background Cards Grid ===== */
.bg-cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  padding-bottom: 8px;
}

.bg-card-item {
  border-radius: 14px;
  overflow: hidden;
  background: var(--card-bg);
  box-shadow: 3px 3px 10px var(--shadow-dark), -2px -2px 6px var(--shadow-light);
  transition: transform 150ms ease;
  position: relative;
}

.bg-card-item:active {
  transform: scale(0.96);
}

.bg-card-active {
  box-shadow: 0 0 0 2px var(--accent), 3px 3px 10px var(--shadow-dark);
}

.bg-card-preview {
  width: 100%;
  height: 80px;
  position: relative;
  overflow: hidden;
  border-radius: 14px;
}

.bg-card-img {
  width: 100%;
  height: 100%;
  display: block;
}

.bg-check-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-check-circle {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.bg-card-label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-primary);
  padding: 8px 10px 2px 10px;
}

.bg-card-theme {
  display: block;
  font-size: 10px;
  color: var(--text-muted);
  padding: 0 10px 10px 10px;
}

/* ===== Old Theme Option (kept for compatibility) ===== */
.theme-option {
  padding: 14px;
  border-radius: 14px;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card-bg);
  box-shadow: 3px 3px 8px var(--shadow-dark);
}

.theme-option-active {
  box-shadow: 0 0 0 2px var(--accent), 3px 3px 8px var(--shadow-dark);
}

.check-mark {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-sm {
  height: 32px;
  border-radius: 8px;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel {
  background: var(--card-bg);
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--accent);
  color: white;
}

/* ===== Locate Button ===== */
.locate-btn {
  padding: 4px 12px;
  border-radius: 9999px;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}

.locate-btn:active {
  transform: scale(0.95);
}

.locate-btn-text {
  font-size: 12px;
  color: var(--accent);
  font-weight: 500;
}

.locating-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid var(--accent-soft);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.auto-locate-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px;
  border-radius: 10px;
  background: var(--accent-soft);
}

.auto-locate-row:active {
  opacity: 0.8;
}

.auto-locate-text {
  font-size: 13px;
  color: var(--accent);
  font-weight: 500;
}

/* ===== Custom Background Delete Button ===== */
.bg-delete-btn {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: rgba(255, 77, 79, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  box-shadow: 0 1px 4px rgba(0,0,0,0.2);
}

.bg-delete-btn:active {
  transform: scale(0.9);
}

/* ===== Add Background Card (Grid Style) ===== */
.bg-add-card-item {
  border-radius: 14px;
  overflow: hidden;
  background: var(--bg);
  border: 2px dashed var(--border);
  box-shadow: none;
  transition: transform 150ms ease;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-add-card-item:active {
  transform: scale(0.96);
  background: var(--accent-soft);
  border-color: var(--accent);
}

.bg-add-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.bg-add-card-text {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
}

/* ===== Idle Days Dropdown List ===== */
.idle-options-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.idle-option-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-radius: 12px;
  background: var(--card-bg);
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light);
  transition: transform 150ms ease;
}

.idle-option-row:active {
  transform: scale(0.98);
}

.idle-option-row-active {
  box-shadow: 0 0 0 2px var(--accent), 3px 3px 8px var(--shadow-dark);
  background: var(--accent-soft);
}

.idle-option-row-text {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
}

.idle-option-row-active .idle-option-row-text {
  color: var(--accent);
  font-weight: 600;
}

.idle-option-check {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.idle-option-check-inner {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Font size utilities */
.text-13px {
  font-size: 13px;
}

.text-12px {
  font-size: 12px;
}

.text-11px {
  font-size: 11px;
}

.text-10px {
  font-size: 10px;
}
