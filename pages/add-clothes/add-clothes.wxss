/* ===== 页面基础 ===== */
.add-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  position: relative;
  overflow: hidden;
}

/* 页面背景装饰光晕 */
.add-page::before {
  content: '';
  position: fixed;
  top: -20%;
  right: -30%;
  width: 80vw;
  height: 80vw;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(176, 137, 104, 0.06) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.add-page::after {
  content: '';
  position: fixed;
  bottom: -10%;
  left: -20%;
  width: 60vw;
  height: 60vw;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(176, 137, 104, 0.04) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ===== Liquid Glass 基础变量 ===== */
.lg-card {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    0 8px 32px rgba(0, 0, 0, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.6),
    inset 0 -1px 0 rgba(255, 255, 255, 0.2);
}

.lg-btn {
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    4px 4px 16px var(--shadow-dark),
    -2px -2px 12px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
}

.lg-inset {
  background: rgba(245, 241, 232, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.35);
  box-shadow:
    inset 3px 3px 10px var(--shadow-inset-dark),
    inset -3px -3px 10px var(--shadow-inset-light),
    0 1px 0 rgba(255, 255, 255, 0.5);
}

/* ===== Safe Area Header ===== */
.safe-header {
  padding-top: 54px;
  background: transparent;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 50px;
  padding: 0 16px;
  margin: 0 12px;
}

.header-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  flex: 1;
  letter-spacing: 0.02em;
}

.header-placeholder {
  min-width: 60px;
}

.back-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.45);
  box-shadow:
    3px 3px 10px var(--shadow-dark),
    -2px -2px 8px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

.back-btn:active {
  box-shadow:
    inset 2px 2px 6px var(--shadow-inset-dark),
    inset -2px -2px 6px var(--shadow-inset-light);
}

.back-icon {
  width: 18px;
  height: 18px;
}

/* ===== Form Scroll Area ===== */
.form-scroll {
  padding: 0 16px;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.safe-header {
  position: relative;
  z-index: 1;
}

/* ===== Photo Upload Row ===== */
.photo-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.photo-box {
  width: 80px;
  height: 80px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 3px 3px 10px var(--shadow-inset-dark),
    inset -3px -3px 10px var(--shadow-inset-light),
    0 2px 8px rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.photo-box-has-image {
  box-shadow:
    4px 4px 14px var(--shadow-dark),
    -3px -3px 12px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.55);
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-icon-wrap {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    3px 3px 8px var(--shadow-dark),
    -2px -2px 8px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
}

.photo-icon {
  width: 14px;
  height: 14px;
}

.album-icon {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1;
}

.photo-text {
  font-size: 10px;
  color: var(--text-secondary);
  font-weight: 500;
}

.photo-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 20px;
}

/* AI Button */
.ai-btn {
  margin-left: auto;
  padding: 10px 18px;
  border-radius: 9999px;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    4px 4px 14px var(--shadow-dark),
    -3px -3px 12px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  gap: 6px;
  transition: all 0.2s ease;
}

.ai-btn:active {
  box-shadow:
    inset 3px 3px 8px var(--shadow-inset-dark),
    inset -2px -2px 8px var(--shadow-inset-light);
}

.ai-btn-icon {
  width: 16px;
  height: 16px;
}

.ai-btn-text {
  color: var(--accent);
  font-size: 13px;
  font-weight: 600;
}

/* ===== Field Group ===== */
.field-group {
  margin-bottom: 20px;
}

.field-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

/* ===== Form Input ===== */
.form-input {
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border-radius: 14px;
  background: rgba(245, 241, 232, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    inset 3px 3px 10px var(--shadow-inset-dark),
    inset -3px -3px 10px var(--shadow-inset-light),
    0 1px 0 rgba(255, 255, 255, 0.5);
  font-size: 14px;
  color: var(--text-primary);
  box-sizing: border-box;
  outline: none;
  transition: all 0.2s ease;
}

.form-input:focus {
  background: rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 3px 3px 10px var(--shadow-inset-dark),
    inset -3px -3px 10px var(--shadow-inset-light),
    0 0 0 2px var(--accent-soft);
}

.form-textarea {
  width: 100%;
  height: 80px;
  padding: 12px 16px;
  border-radius: 14px;
  background: rgba(245, 241, 232, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    inset 3px 3px 10px var(--shadow-inset-dark),
    inset -3px -3px 10px var(--shadow-inset-light),
    0 1px 0 rgba(255, 255, 255, 0.5);
  font-size: 14px;
  color: var(--text-primary);
  box-sizing: border-box;
  outline: none;
}

.input-placeholder {
  color: var(--text-muted);
  font-size: 13px;
}

/* ===== Dropdown Trigger ===== */
.dropdown-trigger {
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border-radius: 14px;
  background: rgba(245, 241, 232, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    inset 3px 3px 10px var(--shadow-inset-dark),
    inset -3px -3px 10px var(--shadow-inset-light),
    0 1px 0 rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.dropdown-trigger:active {
  background: rgba(255, 255, 255, 0.4);
}

.dropdown-text {
  font-size: 14px;
  color: var(--text-muted);
}

.dropdown-text-active {
  color: var(--text-primary);
}

.dropdown-arrow {
  width: 14px;
  height: 14px;
  opacity: 0.5;
}

/* ===== Sub-category ===== */
.subcat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.subcat-hint {
  font-size: 11px;
  color: var(--text-muted);
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 14px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    inset 2px 2px 8px var(--shadow-inset-dark),
    inset -2px -2px 8px var(--shadow-inset-light),
    0 2px 8px rgba(0, 0, 0, 0.04);
}

.tag-pill {
  padding: 8px 18px;
  border-radius: 12px;
  font-size: 13px;
  color: var(--text-muted);
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    3px 3px 8px var(--shadow-dark),
    -2px -2px 8px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
  transition: all 0.2s ease;
}

.tag-pill-active {
  color: var(--accent);
  background: var(--accent-soft);
  box-shadow:
    inset 2px 2px 6px var(--shadow-inset-dark),
    inset -2px -2px 6px var(--shadow-inset-light);
  font-weight: 500;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

/* ===== Color Ribbon ===== */
.color-ribbon-card {
  padding: 16px 18px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    inset 2px 2px 8px var(--shadow-inset-dark),
    inset -2px -2px 8px var(--shadow-inset-light),
    0 2px 8px rgba(0, 0, 0, 0.04);
}

.color-ribbon-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.color-ribbon-row-second {
  margin-top: 10px;
  justify-content: flex-start;
  padding-left: 4px;
}

.color-ribbon-item {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  transition: all 0.2s ease;
}

.color-ribbon-active {
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    3px 3px 8px var(--shadow-dark),
    -2px -2px 8px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
}

.color-ribbon-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  box-shadow:
    2px 2px 6px var(--shadow-dark),
    -1px -1px 3px rgba(255, 255, 255, 0.5);
}

.color-selected-text {
  font-size: 11px;
  color: var(--text-secondary);
  text-align: center;
  margin-top: 8px;
  display: block;
  font-weight: 500;
}

/* ===== Bottom Bar ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom)) 16px;
  background: linear-gradient(to top, var(--bg) 0%, var(--bg) 60%, transparent 100%);
  z-index: 50;
}

.btn-confirm-full {
  width: 100%;
  height: 52px;
  border-radius: 18px;
  background: var(--accent);
  color: white;
  font-size: 15px;
  font-weight: 600;
  border: none;
  box-shadow:
    6px 6px 20px var(--shadow-dark),
    -3px -3px 14px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.btn-confirm-full::after {
  border: none;
}

.btn-confirm-full:active {
  box-shadow:
    inset 4px 4px 12px rgba(0,0,0,0.15),
    inset -2px -2px 8px rgba(255,255,255,0.1);
  transform: scale(0.98);
}

/* 按钮液态玻璃光泽 */
.btn-confirm-full::before {
  content: '';
  position: absolute;
  top: 0;
  left: -50%;
  width: 50%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.15),
    transparent
  );
  animation: shimmer 3s ease-in-out infinite;
}

/* ===== Modal Overlay ===== */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.modal-sheet {
  width: 92vw;
  max-width: 400px;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 28px;
  border: 1px solid rgba(255, 255, 255, 0.6);
  box-shadow:
    0 16px 48px rgba(0, 0, 0, 0.12),
    0 4px 16px rgba(0, 0, 0, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.8),
    inset 0 -1px 0 rgba(255, 255, 255, 0.3);
  overflow: hidden;
  box-sizing: border-box;
  animation: modalIn 0.3s cubic-bezier(0.32, 0.72, 0, 1) forwards;
}

.modal-center {
  margin: auto;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.92) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px 12px 20px;
}

.modal-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    3px 3px 8px var(--shadow-dark),
    -2px -2px 8px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close:active {
  box-shadow:
    inset 2px 2px 6px var(--shadow-inset-dark),
    inset -2px -2px 6px var(--shadow-inset-light);
}

.modal-body {
  padding: 0 20px 20px 20px;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  padding: 0 20px 20px 20px;
}

.btn-confirm-modal {
  height: 46px;
  font-size: 14px;
}

.modal-section-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 10px;
  display: block;
  font-weight: 500;
}

.modal-footer-hint {
  font-size: 11px;
  color: var(--text-muted);
  text-align: center;
  margin-top: 8px;
}

.modal-back-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 12px;
  padding: 6px 0;
}

.modal-back-icon {
  width: 14px;
  height: 14px;
  opacity: 0.5;
}

.modal-back-text {
  font-size: 13px;
  color: var(--accent);
  font-weight: 500;
}

/* ===== Category Grid in Modal ===== */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14px 8px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -3px -3px 10px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
  gap: 6px;
}

.category-card-active {
  color: var(--accent);
  background: var(--accent-soft);
  box-shadow:
    inset 3px 3px 8px var(--shadow-inset-dark),
    inset -3px -3px 8px var(--shadow-inset-light);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.category-card-icon {
  font-size: 24px;
  line-height: 1;
}

.category-card-name {
  font-size: 12px;
  color: var(--text-primary);
}

.category-card-active .category-card-name {
  color: var(--accent);
  font-weight: 500;
}

/* ===== Season Grid in Modal ===== */
.season-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.season-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px 8px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -3px -3px 10px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
}

.season-card-active {
  color: var(--accent);
  background: var(--accent-soft);
  box-shadow:
    inset 3px 3px 8px var(--shadow-inset-dark),
    inset -3px -3px 8px var(--shadow-inset-light);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.season-card-name {
  font-size: 14px;
  color: var(--text-primary);
}

.season-card-active .season-card-name {
  color: var(--accent);
  font-weight: 500;
}

/* ===== Style Grid in Modal ===== */
.style-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.style-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 8px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -3px -3px 10px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
}

.style-card-active {
  color: var(--accent);
  background: var(--accent-soft);
  box-shadow:
    inset 3px 3px 8px var(--shadow-inset-dark),
    inset -3px -3px 8px var(--shadow-inset-light);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.style-card-name {
  font-size: 13px;
  color: var(--text-primary);
}

.style-card-active .style-card-name {
  color: var(--accent);
  font-weight: 500;
}

/* ===== Wardrobe List in Modal ===== */
.wardrobe-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.wardrobe-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -3px -3px 10px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
}

.wardrobe-card-active {
  box-shadow:
    0 0 0 2px var(--accent),
    4px 4px 10px var(--shadow-dark),
    -2px -2px 8px var(--shadow-light);
  background: rgba(255, 255, 255, 0.55);
}

.wardrobe-card-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.wardrobe-card-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
}

.wardrobe-card-desc {
  font-size: 11px;
  color: var(--text-muted);
}

.wardrobe-card-check {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--accent);
  color: white;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== Zone List in Modal ===== */
.zone-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.zone-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    4px 4px 10px var(--shadow-dark),
    -3px -3px 10px var(--shadow-light),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
}

.zone-card-active {
  box-shadow:
    0 0 0 2px var(--accent),
    4px 4px 10px var(--shadow-dark),
    -2px -2px 8px var(--shadow-light);
  background: rgba(255, 255, 255, 0.55);
}

.zone-card-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.zone-card-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
}

.zone-card-type {
  font-size: 11px;
  color: var(--text-muted);
}

.zone-card-check {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--accent);
  color: white;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== AI Overlay ===== */
.ai-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ai-radial-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 50% 40%, rgba(66, 165, 245, 0.12) 0%, transparent 55%);
}

.ai-scan-area {
  position: relative;
  width: 140px;
  height: 140px;
  margin-bottom: 16px;
}

.ai-scan-image-box {
  width: 140px;
  height: 140px;
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, rgba(66, 165, 245, 0.8) 0%, rgba(100, 181, 246, 0.7) 50%, rgba(144, 202, 249, 0.6) 100%);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    0 8px 32px rgba(0, 0, 0, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.5);
}

.ai-grid-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
  background-size: 24px 24px;
}

.ai-bracket {
  position: absolute;
  width: 14px;
  height: 14px;
  border-radius: 2px;
}

.ai-bracket-tl {
  top: -4px;
  left: -4px;
  border-top: 2px solid rgba(255, 255, 255, 0.7);
  border-left: 2px solid rgba(255, 255, 255, 0.7);
}

.ai-bracket-tr {
  top: -4px;
  right: -4px;
  border-top: 2px solid rgba(255, 255, 255, 0.7);
  border-right: 2px solid rgba(255, 255, 255, 0.7);
}

.ai-bracket-bl {
  bottom: -4px;
  left: -4px;
  border-bottom: 2px solid rgba(255, 255, 255, 0.7);
  border-left: 2px solid rgba(255, 255, 255, 0.7);
}

.ai-bracket-br {
  bottom: -4px;
  right: -4px;
  border-bottom: 2px solid rgba(255, 255, 255, 0.7);
  border-right: 2px solid rgba(255, 255, 255, 0.7);
}

.ai-scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(to right, transparent 0%, rgba(66, 165, 245, 0.9) 30%, rgba(66, 165, 245, 0.9) 70%, transparent 100%);
  box-shadow: 0 0 6px 1px rgba(66, 165, 245, 0.4);
  animation: scanLine 2s linear infinite;
  z-index: 10;
}

.ai-rec-tags {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  margin-bottom: 12px;
  min-height: 60px;
}

.ai-rec-tag {
  font-size: 11px;
  padding: 4px 14px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: #90CAF9;
  border: 1px solid rgba(255, 255, 255, 0.25);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
  animation: recTagIn 0.5s ease-out forwards;
  opacity: 0;
}

.ai-success-circle {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 2px solid #30D158;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10px;
}

.ai-success-check {
  color: #30D158;
  font-size: 20px;
}

.ai-success-text {
  color: #30D158;
  font-size: 14px;
  font-weight: 500;
}

.ai-status-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 500;
}

.ai-spinner-box {
  margin-top: 10px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: linear-gradient(135deg, #42A5F5, #64B5F6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 8px rgba(66, 165, 245, 0.4);
  animation: aiSpinner 1.5s linear infinite;
}

.ai-spinner-text {
  color: white;
  font-size: 10px;
}
