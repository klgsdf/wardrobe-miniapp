.ai-page { min-height: 100vh; background: var(--bg); padding-bottom: calc(24px + env(safe-area-inset-bottom)); }

/* ===== Safe Area Header ===== */
.safe-header {
  padding-top: 54px;
  background: var(--bg);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 50px;
  padding: 0 16px;
  margin: 0 12px;
}

.header-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
  text-align: center;
  flex: 1;
}

.header-placeholder {
  min-width: 60px;
}
.form-input { width: 100%; padding: 10px 14px; border-radius: 10px; background: var(--bg); box-shadow: inset 4px 4px 12px var(--shadow-inset-dark), inset -4px -4px 12px var(--shadow-inset-light); font-size: 14px; color: var(--text-primary); box-sizing: border-box; }
.history-pill { padding: 4px 12px; border-radius: 9999px; font-size: 12px; color: var(--text-secondary); background: var(--bg); box-shadow: 2px 2px 6px var(--shadow-dark), -2px -2px 6px var(--shadow-light); }
.ai-btn { height: 48px; border-radius: 12px; background: var(--accent); color: white; font-size: 14px; font-weight: 500; border: none; display: flex; align-items: center; justify-content: center; box-shadow: 4px 4px 14px var(--shadow-dark); }
.ai-btn[disabled] { opacity: 0.3; }
.rec-card { border-radius: 16px; overflow: hidden; background: var(--card-bg); box-shadow: 5px 5px 14px var(--shadow-dark), -3px -3px 14px var(--shadow-light); }
.rank-badge { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: bold; flex-shrink: 0; }
.grid-cols-3 { display: flex; flex-wrap: wrap; }
.grid-cols-3 > view { width: 30%; margin-right: 5%; margin-bottom: 8px; }
.rec-item-card { border-radius: 12px; overflow: hidden; box-shadow: 3px 3px 8px var(--shadow-dark); }
.aspect-square { width: 100%; height: 0; padding-bottom: 100%; }
.object-cover { object-fit: cover; }
.fixed { position: fixed; }
.inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
.text-10px { font-size: 10px; }
.text-11px { font-size: 11px; }
.text-9px { font-size: 9px; }

/* ===== Item Detail Bottom Sheet ===== */
.bs-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  animation: bsFadeIn 300ms ease-out;
}

.bs-overlay-item {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  animation: bsFadeIn 300ms ease-out;
}

@keyframes bsFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.bs-sheet-item {
  background: var(--card-bg);
  border-radius: 28px;
  border: 1px solid rgba(255, 255, 255, 0.5);
  height: 65vh;
  max-height: 65vh;
  width: 88vw;
  max-width: 520px;
  margin: 0 auto calc(24px + env(safe-area-inset-bottom)) auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 -12px 48px var(--shadow-dark),
    0 -4px 16px var(--shadow-dark),
    0 -1px 4px var(--shadow-dark),
    inset 0 1px 0 rgba(255, 255, 255, 0.6);
  transform: translateY(100%);
  transition: transform 400ms cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.bs-sheet-item.bs-sheet-visible {
  transform: translateY(0);
}

.bs-drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 0 8px;
  flex-shrink: 0;
}

.bs-drag-bar {
  width: 44px;
  height: 5px;
  border-radius: 9999px;
  background: var(--text-muted);
  box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1), inset -1px -1px 2px rgba(255,255,255,0.5);
}

.bs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px 12px;
  flex-shrink: 0;
}

.bs-header-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 6px 6px 12px var(--shadow-dark), -6px -6px 12px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bs-header-btn:active {
  transform: scale(0.95);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-header-btn-icon {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1;
  font-weight: 500;
}

.bs-scroll {
  height: calc(78vh - 150px);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 16px;
}

.bs-sheet-item .bs-photo-wrap {
  position: relative;
  margin-bottom: 16px;
}

.bs-sheet-item .bs-photo-carousel {
  width: 100%;
  margin: 0;
  height: calc(88vw * 9 / 16);
  max-height: calc(520px * 9 / 16);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 4px 4px 12px var(--shadow-dark), -2px -2px 8px var(--shadow-light);
}

.bs-sheet-item .bs-photo-img {
  width: 100%;
  height: calc(88vw * 9 / 16);
  max-height: calc(520px * 9 / 16);
  display: block;
  object-fit: cover;
}

.bs-info-area {
  margin-bottom: 12px;
}

.bs-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.2px;
}

.bs-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
  display: block;
}

.bs-tags-area {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.bs-tag-pill {
  padding: 5px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-tag-text {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-colors-area {
  margin-bottom: 16px;
}

.bs-colors-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

.bs-colors-row {
  display: flex;
  gap: 10px;
}

.bs-color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  box-shadow: 3px 3px 8px rgba(0,0,0,0.15), -2px -2px 6px rgba(255,255,255,0.6), inset 0 1px 2px rgba(255,255,255,0.3);
  border: 2px solid rgba(255,255,255,0.5);
}

.bs-location-area {
  margin-bottom: 16px;
}

.bs-location-label-text {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 10px;
  display: block;
  font-weight: 500;
}

.bs-location-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.bs-location-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-location-pill-label {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-location-pill-value {
  font-size: 12px;
  color: var(--text-primary);
  font-weight: 600;
}

.bs-action-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
  background: var(--card-bg);
  flex-shrink: 0;
  box-shadow: 0 -4px 20px var(--shadow-dark);
  border-top: 1px solid rgba(255, 255, 255, 0.5);
}

.bs-close-btn {
  flex: 1;
  height: 46px;
  border-radius: 16px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 4px 4px 10px var(--shadow-dark), -3px -3px 10px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-close-btn:active {
  transform: scale(0.97);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-close-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}
