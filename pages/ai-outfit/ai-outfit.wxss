/* ===== Page Base ===== */
.ai-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ===== Background Image ===== */
.bg-image-wrap {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg,
    rgba(200, 230, 245, 0.3) 0%,
    rgba(180, 220, 240, 0.2) 40%,
    rgba(160, 210, 235, 0.35) 100%);
  backdrop-filter: blur(2px);
}

/* ===== Liquid Glass Card Base ===== */
.glass-card {
  position: relative;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.25) 0%,
    rgba(255, 255, 255, 0.12) 40%,
    rgba(200, 230, 250, 0.18) 60%,
    rgba(255, 255, 255, 0.22) 100%);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    0 8px 32px rgba(80, 140, 180, 0.2),
    0 2px 8px rgba(80, 140, 180, 0.1),
    inset 0 1px 1px rgba(255, 255, 255, 0.6),
    inset 0 -1px 1px rgba(255, 255, 255, 0.2);
  overflow: hidden;
}

/* Liquid shine effect */
.glass-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    135deg,
    transparent 30%,
    rgba(255, 255, 255, 0.15) 45%,
    rgba(255, 255, 255, 0.35) 50%,
    rgba(255, 255, 255, 0.15) 55%,
    transparent 70%
  );
  animation: liquidShine 6s ease-in-out infinite;
  pointer-events: none;
  z-index: 1;
}

@keyframes liquidShine {
  0% { transform: translate(-30%, -30%) rotate(0deg); }
  50% { transform: translate(10%, 10%) rotate(180deg); }
  100% { transform: translate(-30%, -30%) rotate(360deg); }
}

/* Edge highlight for 3D effect */
.glass-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  padding: 1.5px;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.8) 0%,
    rgba(255, 255, 255, 0.3) 30%,
    transparent 50%,
    rgba(255, 255, 255, 0.2) 70%,
    rgba(255, 255, 255, 0.6) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  z-index: 2;
}

/* ===== Header ===== */
.ai-header {
  padding-top: 54px;
  padding-left: 16px;
  padding-right: 16px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.header-back {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(255, 255, 255, 0.15) 100%);
  backdrop-filter: blur(16px) saturate(150%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    3px 3px 10px rgba(80, 140, 180, 0.2),
    -2px -2px 6px rgba(255, 255, 255, 0.3),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
}

.header-back::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.6) 0%,
    transparent 50%,
    rgba(255, 255, 255, 0.2) 100%);
  pointer-events: none;
}

.header-back:active {
  transform: scale(0.95);
  box-shadow: inset 2px 2px 5px rgba(80, 140, 180, 0.15), inset -2px -2px 5px rgba(255, 255, 255, 0.3);
}

.header-back-icon {
  width: 20px;
  height: 20px;
  filter: brightness(0.4);
  position: relative;
  z-index: 1;
}

/* ===== Title Section ===== */
.ai-title-section {
  text-align: center;
  padding: 16px 0 24px;
  position: relative;
  z-index: 1;
}

.ai-title {
  font-size: 28px;
  font-weight: 800;
  color: #1a3a4a;
  display: block;
  letter-spacing: 1px;
  text-shadow: 0 2px 8px rgba(100, 160, 200, 0.25);
}

.ai-subtitle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 10px;
}

.ai-subtitle-icon {
  width: 18px;
  height: 18px;
  opacity: 0.7;
}

.ai-subtitle text {
  font-size: 14px;
  color: #4a7a8a;
  font-weight: 500;
}

/* ===== Scroll Container ===== */
.ai-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  position: relative;
  z-index: 1;
}

/* ===== Input Area ===== */
.input-area {
  padding: 20px;
  min-height: 200px;
}

.input-area::before {
  animation-duration: 8s;
}

.upload-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 18px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(12px);
  box-shadow:
    3px 3px 8px rgba(80, 140, 180, 0.15),
    -2px -2px 6px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
  z-index: 3;
}

.upload-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent);
  animation: shimmer 3s infinite;
}

.upload-btn:active {
  transform: scale(0.97);
}

.upload-icon {
  width: 18px;
  height: 18px;
  opacity: 0.6;
  position: relative;
  z-index: 1;
}

.upload-btn text {
  font-size: 14px;
  color: #3a6a7a;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.input-textarea {
  width: 100%;
  min-height: 80px;
  font-size: 15px;
  color: #2a5a6a;
  line-height: 1.6;
  background: transparent;
  box-sizing: border-box;
  position: relative;
  z-index: 3;
}

.input-textarea::placeholder {
  color: #7aaaba;
}

/* Character Count */
.char-count {
  display: flex;
  justify-content: flex-end;
  margin-top: 10px;
  position: relative;
  z-index: 3;
}

.char-count-text {
  font-size: 12px;
  color: #8ab4c4;
  font-weight: 500;
  transition: color 0.3s ease;
}

.char-count-full {
  color: #e07070;
  font-weight: 600;
}

/* ===== Upload Section ===== */
.upload-section {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
  position: relative;
  z-index: 3;
}

.upload-btn-done {
  background: linear-gradient(145deg,
    rgba(61, 187, 138, 0.25) 0%,
    rgba(42, 168, 118, 0.15) 100%) !important;
  border-color: rgba(61, 187, 138, 0.4) !important;
}

.upload-btn-done text {
  color: #2a8a6a !important;
}

/* Image Preview */
.image-preview-wrap {
  position: relative;
  flex-shrink: 0;
}

.image-preview-thumb {
  width: 72px;
  height: 72px;
  border-radius: 16px;
  object-fit: cover;
  box-shadow:
    0 4px 12px rgba(80, 140, 180, 0.2),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 2px solid rgba(255, 255, 255, 0.6);
}

.image-preview-remove {
  position: absolute;
  top: -8px;
  right: -8px;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(220, 80, 80, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
}

.image-preview-remove text {
  font-size: 12px;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

/* ===== Analysis Steps ===== */
.analysis-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-top: 16px;
  padding: 10px 0;
  position: relative;
  z-index: 3;
}

.analysis-step {
  display: flex;
  align-items: center;
  gap: 8px;
}

.step-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(200, 220, 240, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: #8ab4c4;
  border: 2px solid rgba(180, 200, 220, 0.4);
  transition: all 0.4s ease;
  flex-shrink: 0;
}

.analysis-step-active .step-dot {
  background: linear-gradient(135deg, #3DBB8A, #2AA876);
  color: #fff;
  border-color: #3DBB8A;
  animation: stepPulse 1.5s ease-in-out infinite;
  box-shadow: 0 0 12px rgba(61, 187, 138, 0.4);
}

@keyframes stepPulse {
  0%, 100% { box-shadow: 0 0 8px rgba(61, 187, 138, 0.3); }
  50% { box-shadow: 0 0 20px rgba(61, 187, 138, 0.6); }
}

.analysis-step-done .step-dot {
  background: linear-gradient(135deg, #3DBB8A, #2AA876);
  color: #fff;
  border-color: #3DBB8A;
}

.step-label {
  font-size: 13px;
  color: #6a9aaa;
  font-weight: 500;
  transition: color 0.4s ease;
}

.analysis-step-active .step-label {
  color: #2a8a6a;
  font-weight: 600;
}

.analysis-step-done .step-label {
  color: #2a8a6a;
}

.step-line {
  width: 40px;
  height: 2px;
  background: rgba(180, 200, 220, 0.3);
  margin: 0 8px;
  border-radius: 2px;
  transition: background 0.4s ease;
}

.step-line-done {
  background: linear-gradient(90deg, #3DBB8A, #5BA8E8);
}

/* ===== AI Image Analysis Result ===== */
.analysis-result-card {
  padding: 20px !important;
}

.analysis-result-content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.analysis-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.analysis-label {
  font-size: 12px;
  color: #5a9a9a;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.analysis-value {
  font-size: 16px;
  color: #1a3a4a;
  font-weight: 700;
}

.analysis-desc {
  font-size: 14px;
  color: #2a5a6a;
  line-height: 1.6;
}

.analysis-colors {
  display: flex;
  gap: 8px;
}

.analysis-color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  box-shadow:
    2px 2px 6px rgba(0, 0, 0, 0.1),
    -1px -1px 4px rgba(255, 255, 255, 0.5),
    inset 0 1px 2px rgba(255, 255, 255, 0.3);
  border: 2px solid rgba(255, 255, 255, 0.6);
}

.analysis-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.analysis-mini-tag {
  padding: 5px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(8px);
  box-shadow:
    2px 2px 4px rgba(80, 140, 180, 0.1),
    -1px -1px 3px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  font-size: 12px;
  color: #3a6a7a;
  font-weight: 500;
}

/* AI Thinking Bar */
.ai-thinking-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
  padding: 14px 16px;
  border-radius: 16px;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(200, 230, 250, 0.25) 100%);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow:
    inset 2px 2px 6px rgba(80, 140, 180, 0.08),
    inset -2px -2px 6px rgba(255, 255, 255, 0.4);
  position: relative;
  z-index: 3;
}

.thinking-icon {
  width: 24px;
  height: 24px;
  animation: sparkleRotate 2s ease-in-out infinite;
}

@keyframes sparkleRotate {
  0%, 100% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(10deg) scale(1.1); }
}

.thinking-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.thinking-main {
  font-size: 15px;
  font-weight: 600;
  color: #2a8a6a;
}

.thinking-sub {
  font-size: 12px;
  color: #5a9a9a;
}

/* ===== Action Bar ===== */
.action-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 20px;
  position: relative;
  z-index: 1;
}

.btn-primary {
  flex: 1;
  height: 52px;
  border-radius: 9999px;
  background: linear-gradient(135deg,
    rgba(61, 187, 138, 0.35) 0%,
    rgba(42, 168, 118, 0.35) 100%);
  color: white;
  font-size: 15px;
  font-weight: 600;
  border: 1px solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow:
    0 4px 12px rgba(45, 168, 118, 0.15),
    inset 0 1px 1px rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.32, 0.72, 0, 1);
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
  animation: btnShimmer 2.5s infinite;
}

@keyframes btnShimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 3px 10px rgba(45, 168, 118, 0.3);
}

.btn-primary[disabled] {
  opacity: 0.35;
  box-shadow: none;
}

.btn-primary[disabled]::after {
  animation: none;
}

/* Active state - when input has text */
.btn-primary-active {
  background: linear-gradient(135deg, #3DBB8A 0%, #2AA876 100%);
  box-shadow:
    0 6px 20px rgba(45, 168, 118, 0.4),
    0 2px 6px rgba(45, 168, 118, 0.2),
    inset 0 1px 1px rgba(255, 255, 255, 0.3);
  border: none;
}

.btn-check {
  font-size: 18px;
  font-weight: 700;
  position: relative;
  z-index: 1;
}

.btn-secondary {
  flex: 1;
  height: 52px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(255, 255, 255, 0.15) 100%);
  backdrop-filter: blur(16px) saturate(150%);
  color: #3a6a7a;
  font-size: 15px;
  font-weight: 500;
  border: 1px solid rgba(255, 255, 255, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow:
    0 4px 12px rgba(80, 140, 180, 0.15),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
}

.btn-secondary::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 9999px;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.5) 0%,
    transparent 40%,
    transparent 60%,
    rgba(255, 255, 255, 0.3) 100%);
  pointer-events: none;
}

.btn-secondary:active {
  transform: scale(0.97);
  box-shadow: inset 2px 2px 5px rgba(80, 140, 180, 0.1), inset -2px -2px 5px rgba(255, 255, 255, 0.3);
}

.btn-icon {
  font-size: 16px;
  position: relative;
  z-index: 1;
}

/* ===== History Area ===== */
.history-area {
  padding: 20px;
}

.history-area::before {
  animation-duration: 7s;
  animation-delay: -2s;
}

.history-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  position: relative;
  z-index: 3;
}

.history-header-icon {
  width: 20px;
  height: 20px;
  opacity: 0.55;
}

.history-header-title {
  font-size: 16px;
  font-weight: 700;
  color: #1a3a4a;
}

.history-empty {
  padding: 12px 0;
  text-align: center;
  position: relative;
  z-index: 3;
}

.history-empty text {
  font-size: 13px;
  color: #7aaaba;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  position: relative;
  z-index: 3;
}

.history-tag {
  padding: 10px 18px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(12px);
  box-shadow:
    3px 3px 10px rgba(80, 140, 180, 0.12),
    -2px -2px 6px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  font-size: 14px;
  color: #3a6a7a;
  font-weight: 500;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.history-tag::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent);
  transition: left 0.5s ease;
}

.history-tag:active {
  transform: scale(0.96);
  box-shadow: inset 2px 2px 5px rgba(80, 140, 180, 0.1), inset -2px -2px 5px rgba(255, 255, 255, 0.3);
}

