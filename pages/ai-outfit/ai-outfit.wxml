<view class="container ai-page" data-theme="{{__theme}}">
  <!-- Background Image -->
  <view class="bg-image-wrap">
    <image class="bg-image" src="/images/bg-ai-outfit.jpg" mode="aspectFill" />
    <view class="bg-overlay"></view>
  </view>

  <!-- Header -->
  <view class="ai-header">
    <view class="header-back" bindtap="goBack">
      <image src="/images/icon-back.png" class="header-back-icon" />
    </view>
  </view>

  <!-- Title Section -->
  <view class="ai-title-section">
    <text class="ai-title">穿搭智能推荐</text>
    <view class="ai-subtitle">
      <image src="/images/sparkles.png" class="ai-subtitle-icon" />
      <text>AI 驱动的个性化搭配助手</text>
    </view>
  </view>

  <!-- Main Content -->
  <scroll-view scroll-y class="ai-scroll" enhanced show-scrollbar="{{false}}" >
    <!-- Input Card -->
    <view class="glass-card input-area mx-4">
      <!-- Image Upload & Preview -->
      <view class="upload-section">
        <view class="upload-btn {{uploadedImage ? 'upload-btn-done' : ''}}" bindtap="chooseImage">
          <image src="/images/grid.png" class="upload-icon" />
          <text>{{uploadedImage ? '更换图片' : '上传图片'}}</text>
        </view>
        <!-- Image Preview -->
        <view wx:if="{{uploadedImage}}" class="image-preview-wrap">
          <image class="image-preview-thumb" src="{{uploadedImage}}" mode="aspectFill" />
          <view class="image-preview-remove" bindtap="removeImage">
            <text>✕</text>
          </view>
        </view>
      </view>

      <textarea 
        class="input-textarea" 
        value="{{inputValue}}" 
        bindinput="onInput" 
        placeholder="描述今日穿搭需求或上传图片获取推荐" 
        maxlength="200"
        auto-height
      />
      <view class="char-count">
        <text class="char-count-text {{inputValue.length >= 200 ? 'char-count-full' : ''}}">{{inputValue.length}}/200</text>
      </view>

      <!-- AI Thinking Status -->
      <view wx:if="{{isAnalyzing}}" class="ai-thinking-bar">
        <image src="/images/sparkles.png" class="thinking-icon" />
        <view class="thinking-text">
          <text class="thinking-main">{{analysisStatusText}}</text>
          <text class="thinking-sub">{{analysisStepText}}</text>
        </view>
      </view>
      <!-- Analysis Steps -->
      <view wx:if="{{isAnalyzing}}" class="analysis-steps">
        <view class="analysis-step {{analysisStep >= 1 ? 'analysis-step-done' : ''}} {{analysisStep === 1 ? 'analysis-step-active' : ''}}">
          <view class="step-dot">
            <text wx:if="{{analysisStep > 1}}">✓</text>
            <text wx:elif="{{analysisStep === 1}}">●</text>
            <text wx:else>○</text>
          </view>
          <text class="step-label">图片分析</text>
        </view>
        <view class="step-line {{analysisStep >= 2 ? 'step-line-done' : ''}}"></view>
        <view class="analysis-step {{analysisStep >= 2 ? 'analysis-step-done' : ''}} {{analysisStep === 2 ? 'analysis-step-active' : ''}}">
          <view class="step-dot">
            <text wx:if="{{analysisStep > 2}}">✓</text>
            <text wx:elif="{{analysisStep === 2}}">●</text>
            <text wx:else>○</text>
          </view>
          <text class="step-label">生成方案</text>
        </view>
      </view>
    </view>

    <!-- Action Buttons -->
    <view class="action-bar mx-4">
      <button class="btn-primary {{(hasInput || uploadedImage) ? 'btn-primary-active' : ''}}" bindtap="submit" disabled="{{isAnalyzing || (!hasInput && !uploadedImage)}}">
        <text class="btn-check">✓</text>
        <text>生成推荐</text>
      </button>
      <button class="btn-secondary" bindtap="resetInput">
        <text class="btn-icon">↻</text>
        <text>重置内容</text>
      </button>
    </view>

    <!-- History Section -->
    <view class="glass-card history-area mx-4 mt-4">
      <view class="history-header">
        <image src="/images/calendar.png" class="history-header-icon" />
        <text class="history-header-title">历史记录</text>
      </view>
      <view wx:if="{{searchHistory.length === 0}}" class="history-empty">
        <text>暂无搜索记录</text>
      </view>
      <view wx:else class="history-tags">
        <view wx:for="{{searchHistory}}" wx:key="*this" bindtap="addTag" data-tag="{{item}}" class="history-tag">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- Spacer -->
    <view style="height: 40px;"></view>
  </scroll-view>

  <!-- Hidden Canvas for Image Compression -->
  <canvas type="2d" id="compressCanvas" style="position: fixed; left: -9999px; top: 0; width: 1024px; height: 1024px;"></canvas>
</view>