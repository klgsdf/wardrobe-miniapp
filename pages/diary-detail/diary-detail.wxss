.dd-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg, #F5F1E8);
  overflow: hidden;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
}

/* Safe Header Wrapper */
.safe-header {
  padding-top: 54px;
  background: var(--bg, #F5F1E8);
  flex-shrink: 0;
}

/* Header */
.dd-header {
  padding: 4px 16px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  position: relative;
  z-index: 10;
}

.dd-back-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--card-bg, #EDE8DD), var(--bg, #F5F1E8));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 3px 3px 8px var(--shadow-dark, rgba(160,148,134,0.3)), -2px -2px 6px var(--shadow-light, rgba(255,255,255,0.6));
}

.dd-back-btn:active {
  box-shadow: inset 2px 2px 5px var(--shadow-dark, rgba(160,148,134,0.25)), inset -2px -2px 5px var(--shadow-light, rgba(255,255,255,0.5));
}

.dd-back-icon {
  width: 18px;
  height: 18px;
}

.dd-title {
  flex: 1;
  font-size: 17px;
  font-weight: 700;
  color: var(--text-primary, #4A4036);
  letter-spacing: 0.5px;
}

.dd-share-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--card-bg, #EDE8DD), var(--bg, #F5F1E8));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 3px 3px 8px var(--shadow-dark, rgba(160,148,134,0.3)), -2px -2px 6px var(--shadow-light, rgba(255,255,255,0.6));
}

.dd-share-btn:active {
  box-shadow: inset 2px 2px 5px var(--shadow-dark, rgba(160,148,134,0.25)), inset -2px -2px 5px var(--shadow-light, rgba(255,255,255,0.5));
}

.dd-share-icon {
  width: 18px;
  height: 18px;
  opacity: 0.7;
}

/* Scroll */
.dd-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 16px 24px;
}

/* Photo */
.dd-photo-card {
  border-radius: 18px;
  overflow: hidden;
  background: var(--card-bg, #EDE8DD);
  box-shadow: 8px 8px 20px var(--shadow-dark, rgba(160,148,134,0.35)), -6px -6px 20px var(--shadow-light, rgba(255,255,255,0.7));
  margin: 0 4px 16px;
}

.dd-photo-img {
  width: 100%;
  height: 240px;
  display: block;
}

/* Info Card */
.dd-info-card {
  border-radius: 16px;
  padding: 16px;
  background: var(--card-bg, #EDE8DD);
  box-shadow: 6px 6px 16px var(--shadow-dark, rgba(160,148,134,0.35)), -4px -4px 16px var(--shadow-light, rgba(255,255,255,0.7));
  margin: 0 4px 12px;
}

.dd-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.dd-name {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary, #4A4036);
}

.dd-style-badge {
  display: inline-flex;
  padding: 4px 12px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 500;
  background: var(--accent-soft, rgba(176,137,104,0.12));
  color: var(--accent, #B08968);
}

.dd-info-row2 {
  display: flex;
  align-items: center;
  gap: 8px;
}

.dd-icon-sm {
  width: 14px;
  height: 14px;
}

.dd-date-badge {
  display: inline-flex;
  padding: 4px 12px;
  border-radius: 8px;
  font-size: 12px;
  background: var(--bg, #F5F1E8);
  color: var(--text-secondary, #7A6E62);
  box-shadow: inset 2px 2px 5px var(--shadow-inset-dark, rgba(160,148,134,0.22)), inset -2px -2px 5px var(--shadow-inset-light, rgba(255,255,255,0.55));
}

/* Section */
.dd-section {
  margin: 0 4px 12px;
}

.dd-section-title {
  font-size: 11px;
  color: var(--text-muted, #9C8E82);
  margin-bottom: 8px;
  display: block;
  letter-spacing: 0.05em;
}

/* Note */
.dd-note-box {
  border-radius: 12px;
  padding: 12px;
  background: var(--bg, #F5F1E8);
  box-shadow: inset 3px 3px 8px var(--shadow-inset-dark, rgba(160,148,134,0.22)), inset -3px -3px 8px var(--shadow-inset-light, rgba(255,255,255,0.55));
  font-size: 13px;
  color: var(--text-secondary, #7A6E62);
  line-height: 1.6;
  margin: 0 4px;
}

/* Cloth Item */
.dd-cloth-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 12px;
  border-radius: 14px;
  background: var(--card-bg, #EDE8DD);
  box-shadow: 4px 4px 12px var(--shadow-dark, rgba(160,148,134,0.3)), -3px -3px 10px var(--shadow-light, rgba(255,255,255,0.7));
  margin: 0 4px 10px;
}

.dd-cloth-img {
  width: 48px;
  height: 48px;
  border-radius: 10px;
  object-fit: cover;
  box-shadow: 2px 2px 5px var(--shadow-dark, rgba(160,148,134,0.3));
  flex-shrink: 0;
}

.dd-cloth-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.dd-cloth-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary, #4A4036);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.dd-cloth-meta {
  font-size: 11px;
  color: var(--text-muted, #9C8E82);
  margin-top: 4px;
  display: block;
}

.dd-cloth-tag {
  flex-shrink: 0;
  display: inline-flex;
  padding: 5px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
  background: linear-gradient(135deg, rgba(176,137,104,0.15), rgba(176,137,104,0.08));
  color: var(--accent, #B08968);
  margin-left: 4px;
}

/* Bottom Bar */
.dd-bottom-bar {
  display: flex;
  gap: 16px;
  padding: 12px 16px calc(24px + env(safe-area-inset-bottom));
  background: var(--bg, #F5F1E8);
  flex-shrink: 0;
  box-shadow: 0 -4px 20px var(--shadow-dark);
}

.dd-action-btn {
  flex: 1;
  height: 46px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.5px;
  transition: all 0.15s ease;
}

.dd-edit-btn {
  background: linear-gradient(145deg, var(--card-bg, #EDE8DD), var(--bg, #F5F1E8));
  color: var(--text-primary, #4A4036);
  box-shadow: 4px 4px 10px var(--shadow-dark, rgba(160,148,134,0.3)), -3px -3px 8px var(--shadow-light, rgba(255,255,255,0.6));
}

.dd-edit-btn:active {
  box-shadow: inset 3px 3px 6px var(--shadow-dark, rgba(160,148,134,0.25)), inset -2px -2px 5px var(--shadow-light, rgba(255,255,255,0.5));
}

.dd-delete-btn {
  background: linear-gradient(145deg, var(--accent-soft), rgba(193, 124, 116, 0.1));
  color: var(--accent-warm);
  box-shadow: 4px 4px 10px var(--shadow-dark), -3px -3px 8px var(--shadow-light);
}

.dd-delete-btn:active {
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -2px -2px 5px var(--shadow-inset-light);
}

/* ===== Item Detail Modal (Center) ===== */
.bs-overlay-item {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  animation: bsFadeIn 300ms ease-out;
}

@keyframes bsFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.bs-sheet-item {
  background: var(--card-bg);
  border-radius: 28px;
  border: 1px solid rgba(255, 255, 255, 0.5);
  height: 65vh;
  max-height: 65vh;
  width: 84vw;
  max-width: 480px;
  margin: 0 auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 12px 48px var(--shadow-dark),
    0 4px 16px var(--shadow-dark),
    0 1px 4px var(--shadow-dark),
    inset 0 1px 0 rgba(255, 255, 255, 0.6);
  transform: scale(0.9);
  opacity: 0;
  transition: all 400ms cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.bs-sheet-item.bs-sheet-visible {
  transform: scale(1);
  opacity: 1;
}

.bs-drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 0 8px;
  flex-shrink: 0;
}

.bs-drag-bar {
  width: 44px;
  height: 5px;
  border-radius: 9999px;
  background: var(--text-muted);
  box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1), inset -1px -1px 2px rgba(255,255,255,0.5);
}

.bs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px 12px;
  flex-shrink: 0;
}

.bs-header-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 6px 6px 12px var(--shadow-dark), -6px -6px 12px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bs-header-btn:active {
  transform: scale(0.95);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-header-btn-icon {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1;
  font-weight: 500;
}

.bs-scroll {
  height: calc(78vh - 150px);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 16px;
}

.bs-sheet-item .bs-photo-wrap {
  position: relative;
  margin-bottom: 16px;
}

.bs-sheet-item .bs-photo-carousel {
  width: 100%;
  margin: 0;
  height: calc(84vw * 9 / 16);
  max-height: calc(480px * 9 / 16);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 4px 4px 12px var(--shadow-dark), -2px -2px 8px var(--shadow-light);
}

.bs-sheet-item .bs-photo-img {
  width: 100%;
  height: calc(84vw * 9 / 16);
  max-height: calc(480px * 9 / 16);
  display: block;
  object-fit: cover;
}

.bs-info-area {
  margin-bottom: 12px;
}

.bs-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.2px;
}

.bs-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
  display: block;
}

.bs-tags-area {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.bs-tag-pill {
  padding: 5px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-tag-text {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-colors-area {
  margin-bottom: 16px;
}

.bs-colors-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

.bs-colors-row {
  display: flex;
  gap: 10px;
}

.bs-color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  box-shadow: 3px 3px 8px rgba(0,0,0,0.15), -2px -2px 6px rgba(255,255,255,0.6), inset 0 1px 2px rgba(255,255,255,0.3);
  border: 2px solid rgba(255,255,255,0.5);
}

.bs-location-area {
  margin-bottom: 16px;
}

.bs-location-label-text {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 10px;
  display: block;
  font-weight: 500;
}

.bs-location-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.bs-location-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-location-pill-label {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-location-pill-value {
  font-size: 12px;
  color: var(--text-primary);
  font-weight: 600;
}

.bs-action-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
  background: var(--card-bg);
  flex-shrink: 0;
  box-shadow: 0 -4px 20px var(--shadow-dark);
  border-top: 1px solid rgba(255, 255, 255, 0.5);
}

.bs-edit-btn {
  flex: 1;
  height: 44px;
  border-radius: 16px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 4px 4px 10px var(--shadow-dark), -3px -3px 10px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-edit-btn:active {
  transform: scale(0.97);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-edit-icon {
  font-size: 14px;
  color: var(--text-primary);
}

.bs-edit-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.bs-delete-btn {
  flex: 1;
  height: 44px;
  border-radius: 16px;
  background: linear-gradient(135deg, var(--accent-warm), var(--accent-coral));
  box-shadow: 3px 3px 10px rgba(184, 104, 96, 0.3), -2px -2px 6px rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.bs-delete-btn:active {
  transform: scale(0.97);
  box-shadow: inset 3px 3px 8px rgba(150, 80, 70, 0.4), inset -2px -2px 6px rgba(255,255,255,0.2);
}

.bs-delete-icon {
  font-size: 14px;
  color: #FFFFFF;
}

.bs-delete-text {
  font-size: 14px;
  font-weight: 600;
  color: #FFFFFF;
}
