.splash-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 300;
}

.splash-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 45%, var(--accent-soft) 0%, transparent 60%);
  opacity: 0.6;
  
}

.splash-leaf-wrap {
  position: relative;
  margin-bottom: 24px;
}

.splash-leaf {
  animation: leafFloat 3s ease-in-out infinite;
}

.splash-ring {
  position: absolute;
  inset: -20px;
  border: 1px solid var(--accent);
  border-radius: 50%;
  opacity: 0.15;
  animation: ringPulse 2.5s ease-in-out infinite;
}

.splash-brand {
  text-align: center;
}

.splash-char {
  display: inline-block;
  font-size: 28px;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: var(--text-primary);
  opacity: 0;
  animation: charIn 0.5s ease-out forwards;
}

.splash-subtitle {
  margin-top: 12px;
  font-size: 13px;
  color: var(--text-secondary);
  letter-spacing: 0.3em;
  opacity: 0;
  animation: fadeInUp 0.6s ease-out 1s forwards;
}

.splash-dots {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 40px;
}

.splash-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent);
  animation: dotBounce 1.2s ease-in-out infinite;
}

/* Keyframes (defined in app.wxss): charIn, fadeInUp, dotBounce, leafFloat */
/* ringPulse is referenced but not defined in app.wxss - define locally */
@keyframes ringPulse {
  0% { transform: scale(1); opacity: 0.15; }
  50% { transform: scale(1.3); opacity: 0; }
  100% { transform: scale(1); opacity: 0.15; }
}
