.splash-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 300;
  overflow: hidden;
  user-select: none;
}

/* 主容器 */
.splash-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

/* SVG 容器 */
.splash-svg-container {
  position: relative;
}

.splash-svg {
  position: absolute;
  inset: 0;
}

/* 浮动布料碎片 */
.splash-cloth-piece {
  position: absolute;
  will-change: transform, opacity;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

/* 品牌名称 */
.splash-brand {
  text-align: center;
}

.splash-char {
  display: inline-block;
  font-size: 28px;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: var(--text-primary, #333333);
  opacity: 0;
  animation: charIn 0.5s ease-out forwards;
}

/* 欢迎文字逐个字符弹出动画 */
.splash-welcome-char {
  display: inline-block;
  font-size: 24px;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: #000000;
  opacity: 0;
  animation: welcomeCharPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 进度条区域 */
.splash-progress {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.splash-phase-text {
  height: 20px;
  overflow: hidden;
  position: relative;
  width: 100%;
  text-align: center;
}

.splash-phase-animate {
  font-size: 14px;
  color: var(--text-secondary, #888888);
  animation: fadeInUp 0.3s ease-out forwards;
}

.splash-progress-bar {
  width: 200px;
  height: 4px;
  border-radius: 2px;
  background: #E5E0D8;
  overflow: hidden;
}

.splash-progress-fill {
  height: 100%;
  border-radius: 2px;
  transition: all 0.1s ease-linear;
}

.splash-percent {
  font-size: 12px;
  transition: color 0.3s;
}

/* 版本号和提示 */
.splash-version {
  position: absolute;
  bottom: 32px;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 11px;
  color: #CCCCCC;
}

.splash-hint {
  position: absolute;
  top: 32px;
  right: 24px;
  font-size: 12px;
  color: #CCCCCC;
  transition: opacity 0.3s;
}

/* 动画关键帧 */
@keyframes charIn {
  0% {
    opacity: 0;
    transform: translateY(10px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  0% {
    opacity: 0;
    transform: translateY(10px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 布料浮动动画 */
@keyframes clothFloat1 {
  0%, 100% {
    transform: scale(1) rotate(15deg) translateY(0);
  }
  50% {
    transform: scale(1) rotate(18deg) translateY(-5px);
  }
}

@keyframes clothFloat2 {
  0%, 100% {
    transform: scale(1) rotate(-10deg) translateY(0);
  }
  50% {
    transform: scale(1) rotate(-7deg) translateY(-4px);
  }
}

@keyframes clothFloat3 {
  0%, 100% {
    transform: scale(1) rotate(20deg) translateY(0);
  }
  50% {
    transform: scale(1) rotate(23deg) translateY(-6px);
  }
}

@keyframes clothFloat4 {
  0%, 100% {
    transform: scale(1) rotate(-5deg) translateY(0);
  }
  50% {
    transform: scale(1) rotate(-2deg) translateY(-4px);
  }
}

@keyframes clothFloat5 {
  0%, 100% {
    transform: scale(1) rotate(25deg) translateY(0);
  }
  50% {
    transform: scale(1) rotate(28deg) translateY(-5px);
  }
}

/* 页面退出动画 */
.page-exit {
  opacity: 0;
  transition: opacity 0.4s ease-out;
}

/* 欢迎文字弹性缩放弹出动画 */
@keyframes welcomeCharPop {
  0% {
    opacity: 0;
    transform: scale(0.3) translateY(20px);
  }
  60% {
    opacity: 1;
    transform: scale(1.15) translateY(-5px);
  }
  80% {
    transform: scale(0.95) translateY(2px);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* 减少动画偏好设置 */
@media (prefers-reduced-motion: reduce) {
  .splash-cloth-piece,
  .splash-char,
  .splash-welcome-char,
  .splash-phase-animate,
  .splash-progress-fill,
  .splash-percent,
  .splash-hint,
  .splash-main,
  .splash-brand,
  .splash-cloth-group {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  
  .splash-cloth-piece {
    animation: none !important;
  }
}
