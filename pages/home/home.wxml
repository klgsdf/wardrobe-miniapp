<view class="container home-page" data-theme="{{__theme}}" bindtap="onPageTap">
  <!-- 背景图片 + 渐变叠加 -->
  <view class="bg-image-wrap">
    <image class="bg-image" src="{{bgImage}}" mode="aspectFill" />
    <view class="bg-gradient-overlay"></view>
  </view>

  <!-- Header -->
  <view class="header" style="padding-top: {{safeTop}}px;">
    <view class="header-content flex items-center gap-3 px-4 py-2">
      <!-- Wardrobe name with dropdown -->
      <view class="relative" catchtap="onHeaderTap">
        <view class="flex items-center gap-1" bindtap="toggleDropdown">
          <text class="text-display wardrobe-name-text" style="color: {{isLightBgTheme ? '#FFFFFF' : 'var(--text-primary)'}};">{{wardrobeName}}</text>
          <image src="/images/chevron-down.png" class="icon-sm" style="filter: {{isLightBgTheme ? 'brightness(10)' : 'none'}};" />
        </view>

        <!-- Dropdown Menu -->
        <view wx:if="{{showDropdown}}" class="dropdown-menu" catchtap="onDropdownTap">
          <view wx:if="{{!editingName}}">
            <view class="dropdown-item" bindtap="startEditName">
              <text>重命名</text>
            </view>
            <view class="dropdown-divider"></view>
            <view class="dropdown-item" bindtap="goToSettings">
              <text>设置</text>
            </view>
          </view>
          <view wx:else class="edit-name-area">
            <input
              class="edit-name-input"
              value="{{editNameValue}}"
              bindinput="onNameInput"
              placeholder="输入名称（最多5字）"
              maxlength="5"
              focus
            />
            <view class="flex gap-2 mt-2">
              <button class="btn-sm btn-cancel" bindtap="cancelRename">取消</button>
              <button class="btn-sm btn-confirm" bindtap="confirmRename">确认</button>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Stats Strip -->
  <view class="card stats-bar mx-4 mt-2">
    <view class="stat-col">
      <text class="text-stat">{{outfitCount}}</text>
      <text class="text-stat-label mt-1">衣物数量</text>
    </view>
    <view class="divider"></view>
    <view class="stat-col">
      <text class="text-stat">{{monthlyWorn}}</text>
      <text class="text-stat-label mt-1">本月穿过</text>
    </view>
    <view class="divider"></view>
    <view class="stat-col">
      <text class="text-stat">{{idleCount}}</text>
      <text class="text-stat-label mt-1">闲置数量</text>
    </view>
  </view>

  <!-- Weather + AI Row -->
  <view class="weather-ai-row flex gap-3 mx-4 mt-2">
    <!-- Weather Card -->
    <view class="weather-card flex-1" bindtap="refreshWeather">
      <image class="weather-bg img-cover" src="{{weatherBg}}" mode="aspectFill" />
      <view class="weather-overlay"></view>
      <view class="weather-content relative z-10">
        <view class="weather-top-row">
          <image src="{{weatherIcon}}" class="weather-icon" />
          <text class="temp-text">{{temperature}}°C</text>
          <view wx:if="{{weatherLoading}}" class="weather-loading"></view>
        </view>
        <view class="weather-bottom-row">
          <text class="location-text">{{city}} · {{weather}}</text>
          <text class="greeting-text">{{greeting}} {{userNickname}}</text>
        </view>
      </view>
    </view>

    <!-- AI Outfit Card -->
    <view class="ai-card flex-1">
      <view class="ai-bg-overlay"></view>
      <view class="relative z-10">
        <view class="flex items-center gap-1_5 mb-1">
          <image src="/images/sparkles.png" class="icon-xs" style="opacity: 0.7;" />
          <text class="ai-card-title">AI 智能搭配</text>
        </view>
        <text class="ai-card-desc">根据天气和场合推荐穿搭</text>
      </view>
      <view class="rainbow-btn-wrapper relative z-10" bindtap="goToAIOutfit">
        <button class="rainbow-btn-inner">开始搭配</button>
      </view>
    </view>
  </view>

  <!-- Outfit Diary Section -->
  <view class="diary-section mx-4 mt-2">
    <view class="diary-section-header">
      <view class="diary-section-title">
        <view class="diary-section-bar"></view>
        <text class="diary-section-title-text">穿搭日记</text>
      </view>
      <view class="diary-view-all" bindtap="goToDiary">
        <text>查看所有</text>
        <image src="/images/chevron-right.png" class="icon-xs" />
      </view>
    </view>

    <!-- Horizontal scrollable card container with edge fade -->
    <view wx:if="{{diaryOutfits.length > 0}}" class="diary-scroll-wrap">
      <scroll-view class="diary-scroll-area" scroll-x="true" enable-flex="true">
        <view class="diary-card-list">
          <view wx:for="{{diaryOutfits}}" wx:key="id" class="diary-card" bindtap="showDiaryDetail" data-id="{{item.id}}">
            <view class="diary-card-img-wrap">
              <image class="diary-card-img" src="{{item.photos[0] || '/images/outfit-thumb-1.jpg'}}" mode="aspectFill" />
            </view>
            <view class="diary-card-info">
              <text class="diary-card-name">{{item.name}}</text>
              <view class="diary-card-meta">
                <text class="diary-card-style">{{item.style}}</text>
                <text class="diary-card-date">{{item.date}}</text>
              </view>
              <text wx:if="{{item.note}}" class="diary-card-note">{{item.note}}</text>
              <view wx:if="{{item.clothingItemIds && item.clothingItemIds.length > 0}}" class="diary-card-items-glass">
                <text class="diary-card-items-label">包含单品</text>
                <text class="diary-card-items-text">{{item.clothingItemNames}}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="diary-fade-left"></view>
      <view class="diary-fade-right"></view>
    </view>
    <view wx:else class="diary-empty-area">
      <view class="empty-state flex flex-col items-center justify-center h-full">
        <view class="w-12 h-12 rounded-2xl flex items-center justify-center mb-2" style="background: var(--accent-soft);">
          <image src="/images/shirt.png" class="icon-md" />
        </view>
        <text class="text-13px font-medium" style="color: var(--text-primary);">还没有记录</text>
        <text class="text-11px mt-0_5" style="color: var(--text-muted);">去日记页面添加穿搭</text>
      </view>
    </view>
  </view>

  <!-- Toast -->
  <view wx:if="{{toastMessage}}" class="toast animate-toast-in">{{toastMessage}}</view>

  <!-- Diary Detail Modal - 复刻日记页弹窗 -->
  <view wx:if="{{showDetailSheet}}" class="bs-overlay" bindtap="hideDiaryDetail">
    <view class="bs-sheet {{showDetailSheet ? 'bs-sheet-visible' : ''}}" catchtap="preventBubble">
      <!-- Drag Handle -->
      <view class="bs-drag-handle" bindtap="hideDiaryDetail">
        <view class="bs-drag-bar"></view>
      </view>

      <!-- Header: Close + Share -->
      <view class="bs-header">
        <view bindtap="hideDiaryDetail" class="bs-header-btn">
          <text class="bs-header-btn-icon">✕</text>
        </view>
        <view bindtap="shareDiaryEntry" class="bs-header-btn">
          <text class="bs-header-btn-icon" style="font-size: 16px;">↗</text>
        </view>
      </view>

      <!-- Content -->
      <scroll-view class="bs-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <!-- Photo Carousel -->
        <view class="bs-photo-wrap" wx:if="{{detailEntry && detailEntry.photos && detailEntry.photos.length > 0}}">
          <scroll-view class="bs-photo-carousel" scroll-x enhanced show-scrollbar="{{false}}" scroll-snap-type="x mandatory">
            <view wx:for="{{detailEntry.photos}}" wx:key="*this" class="bs-photo-item" style="scroll-snap-align: center;">
              <image class="bs-photo-img" src="{{item}}" mode="aspectFill" />
            </view>
          </scroll-view>
          <!-- Pagination Dots -->
          <view class="bs-photo-dots" wx:if="{{detailEntry.photos.length > 1}}">
            <view wx:for="{{detailEntry.photos}}" wx:key="*this" class="bs-photo-dot {{index === 0 ? 'bs-photo-dot-active' : ''}}"></view>
          </view>
        </view>

        <!-- Title & Meta -->
        <view class="bs-info-area" wx:if="{{detailEntry}}">
          <text class="bs-title">{{detailEntry.name}}</text>
          <text class="bs-desc">{{detailEntry.note || ''}}{{detailEntry.weather ? ' · ' + detailEntry.weather : ''}}{{detailEntry.date ? ' · ' + detailEntry.date : ''}}</text>
        </view>

        <!-- Clothing Items -->
        <view class="bs-items-area" wx:if="{{detailItems.length > 0}}">
          <view wx:for="{{detailItems}}" wx:key="id" class="bs-item-card" bindtap="showItemDetailFromSheet" data-id="{{item.id}}">
            <image class="bs-item-img" src="{{item.image}}" mode="aspectFill" />
            <view class="bs-item-info">
              <text class="bs-item-name">{{item.name}}</text>
              <text class="bs-item-meta">{{item.category}} · {{item.subcategory || item.subCategory || ''}}</text>
            </view>
            <view class="bs-item-tag">
              <text class="bs-item-tag-text">{{item.category}}</text>
            </view>
          </view>
        </view>

        <view style="height: 20px;"></view>
      </scroll-view>

      <!-- Bottom Actions -->
      <view class="bs-action-bar">
        <view class="bs-edit-btn" bindtap="editDiaryEntry">
          <text class="bs-edit-icon">✎</text>
          <text class="bs-edit-text">编辑</text>
        </view>
        <view class="bs-delete-btn" bindtap="deleteDiaryEntry">
          <text class="bs-delete-icon">🗑</text>
          <text class="bs-delete-text">删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Item Detail Modal -->
  <view wx:if="{{showItemDetailSheet}}" class="bs-overlay-item" bindtap="hideItemDetail">
    <view class="bs-sheet bs-sheet-item {{showItemDetailSheet ? 'bs-sheet-visible' : ''}}" catchtap="preventBubble">
      <!-- Header -->
      <view class="bs-header">
        <view bindtap="hideItemDetail" class="bs-header-btn">
          <text class="bs-header-btn-icon">✕</text>
        </view>
      </view>

      <!-- Content -->
      <scroll-view class="bs-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <!-- Photo -->
        <view class="bs-photo-wrap" wx:if="{{detailItem}}">
          <view class="bs-photo-carousel">
            <image class="bs-photo-img" src="{{detailItem.image}}" mode="aspectFill" />
          </view>
        </view>

        <!-- Info -->
        <view class="bs-info-area" wx:if="{{detailItem}}">
          <text class="bs-title">{{detailItem.name}}</text>
          <text class="bs-desc">{{detailItem.category}} · {{detailItem.subCategory || detailItem.subcategory || ''}} · {{detailItem.style}}</text>
        </view>

        <!-- Tags -->
        <view class="bs-tags-area" wx:if="{{detailItem}}">
          <view class="bs-tag-pill" wx:for="{{detailItem.seasons}}" wx:key="*this">
            <text class="bs-tag-text">{{item}}</text>
          </view>
        </view>

        <!-- Colors -->
        <view class="bs-colors-area" wx:if="{{detailItem && detailItem.colors}}">
          <text class="bs-colors-label">颜色</text>
          <view class="bs-colors-row">
            <view wx:for="{{detailItem.colors}}" wx:key="*this" class="bs-color-dot" style="background: {{item}};"></view>
          </view>
        </view>

        <!-- Location -->
        <view class="bs-location-area" wx:if="{{detailItem}}">
          <view class="bs-location-label-text">位置信息</view>
          <view class="bs-location-pills">
            <view class="bs-location-pill">
              <text class="bs-location-pill-label">衣柜</text>
              <text class="bs-location-pill-value">{{detailWardrobeName}}</text>
            </view>
            <view class="bs-location-pill">
              <text class="bs-location-pill-label">分区</text>
              <text class="bs-location-pill-value">{{detailZoneName}}</text>
            </view>
          </view>
        </view>

        <view style="height: 20px;"></view>
      </scroll-view>

      <!-- Bottom Actions -->
      <view class="bs-action-bar">
        <view class="bs-edit-btn" bindtap="editItemDetail">
          <text class="bs-edit-icon">✎</text>
          <text class="bs-edit-text">编辑</text>
        </view>
        <view class="bs-delete-btn" bindtap="deleteItemDetail">
          <text class="bs-delete-icon">🗑</text>
          <text class="bs-delete-text">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>
