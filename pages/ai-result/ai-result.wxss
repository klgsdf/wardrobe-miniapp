  backdrop-filter: blur(16px) saturate(150%);
  color: #3a6a7a;
  font-size: 15px;
  font-weight: 600;
  border: 1px solid rgba(255, 255, 255, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow:
    0 4px 12px rgba(80, 140, 180, 0.15),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
}

.btn-home::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 9999px;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.5) 0%,
    transparent 40%,
    transparent 60%,
    rgba(255, 255, 255, 0.3) 100%);
  pointer-events: none;
}

.btn-home:active {
