/* ===== Page Base ===== */
.ai-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ===== Background Image ===== */
.bg-image-wrap {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg,
    rgba(200, 230, 245, 0.3) 0%,
    rgba(180, 220, 240, 0.2) 40%,
    rgba(160, 210, 235, 0.35) 100%);
  backdrop-filter: blur(2px);
}

/* ===== Liquid Glass Card Base ===== */
.glass-card {
  position: relative;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.25) 0%,
    rgba(255, 255, 255, 0.12) 40%,
    rgba(200, 230, 250, 0.18) 60%,
    rgba(255, 255, 255, 0.22) 100%);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow:
    0 8px 32px rgba(80, 140, 180, 0.2),
    0 2px 8px rgba(80, 140, 180, 0.1),
    inset 0 1px 1px rgba(255, 255, 255, 0.6),
    inset 0 -1px 1px rgba(255, 255, 255, 0.2);
  overflow: hidden;
}

/* Liquid shine effect */
.glass-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    135deg,
    transparent 30%,
    rgba(255, 255, 255, 0.15) 45%,
    rgba(255, 255, 255, 0.35) 50%,
    rgba(255, 255, 255, 0.15) 55%,
    transparent 70%
  );
  animation: liquidShine 6s ease-in-out infinite;
  pointer-events: none;
  z-index: 1;
}

@keyframes liquidShine {
  0% { transform: translate(-30%, -30%) rotate(0deg); }
  50% { transform: translate(10%, 10%) rotate(180deg); }
  100% { transform: translate(-30%, -30%) rotate(360deg); }
}

/* Edge highlight for 3D effect */
.glass-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  padding: 1.5px;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.8) 0%,
    rgba(255, 255, 255, 0.3) 30%,
    transparent 50%,
    rgba(255, 255, 255, 0.2) 70%,
    rgba(255, 255, 255, 0.6) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  z-index: 2;
}

/* ===== Header ===== */
.ai-header {
  padding-top: 54px;
  padding-left: 16px;
  padding-right: 16px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.header-back {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(255, 255, 255, 0.15) 100%);
  backdrop-filter: blur(16px) saturate(150%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    3px 3px 10px rgba(80, 140, 180, 0.2),
    -2px -2px 6px rgba(255, 255, 255, 0.3),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
}

.header-back::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.6) 0%,
    transparent 50%,
    rgba(255, 255, 255, 0.2) 100%);
  pointer-events: none;
}

.header-back:active {
  transform: scale(0.95);
  box-shadow: inset 2px 2px 5px rgba(80, 140, 180, 0.15), inset -2px -2px 5px rgba(255, 255, 255, 0.3);
}

.header-back-icon {
  width: 20px;
  height: 20px;
  filter: brightness(0.4);
  position: relative;
  z-index: 1;
}

/* ===== Title Section ===== */
.ai-title-section {
  text-align: center;
  padding: 16px 0 24px;
  position: relative;
  z-index: 1;
}

.ai-title {
  font-size: 28px;
  font-weight: 800;
  color: #1a3a4a;
  display: block;
  letter-spacing: 1px;
  text-shadow: 0 2px 8px rgba(100, 160, 200, 0.25);
}

.ai-subtitle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 10px;
}

.ai-subtitle-icon {
  width: 18px;
  height: 18px;
  opacity: 0.7;
}

.ai-subtitle text {
  font-size: 14px;
  color: #4a7a8a;
  font-weight: 500;
}

/* ===== Scroll Container ===== */
.ai-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  position: relative;
  z-index: 1;
}

/* ===== Utility Spacing ===== */
.mx-4 {
  margin-left: 16px;
  margin-right: 16px;
}

/* ===== AI Image Analysis Result ===== */
.analysis-result-card {
  padding: 20px !important;
}

.analysis-result-content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.analysis-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.analysis-label {
  font-size: 12px;
  color: #5a9a9a;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.analysis-value {
  font-size: 16px;
  color: #1a3a4a;
  font-weight: 700;
}

.analysis-desc {
  font-size: 14px;
  color: #2a5a6a;
  line-height: 1.6;
}

.analysis-colors {
  display: flex;
  gap: 8px;
}

.analysis-color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  box-shadow:
    2px 2px 6px rgba(0, 0, 0, 0.1),
    -1px -1px 4px rgba(255, 255, 255, 0.5),
    inset 0 1px 2px rgba(255, 255, 255, 0.3);
  border: 2px solid rgba(255, 255, 255, 0.6);
}

.analysis-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.analysis-mini-tag {
  padding: 5px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(8px);
  box-shadow:
    2px 2px 4px rgba(80, 140, 180, 0.1),
    -1px -1px 3px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  font-size: 12px;
  color: #3a6a7a;
  font-weight: 500;
}

/* ===== Result Section ===== */
.result-section {
