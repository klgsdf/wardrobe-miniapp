}

.item-row-category {
  padding: 3px 10px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.5) 0%,
    rgba(255, 255, 255, 0.3) 100%);
  box-shadow:
    1px 1px 4px rgba(80, 140, 180, 0.1),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  font-size: 11px;
  color: #4a7a8a;
  font-weight: 500;
  flex-shrink: 0;
}

.item-row-meta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.item-row-status {
  font-size: 12px;
  color: #3DBB8A;
  font-weight: 500;
}

.item-row-match {
  font-size: 12px;
  font-weight: 600;
}

.item-row-arrow {
  width: 16px;
  height: 16px;
  opacity: 0.35;
  flex-shrink: 0;
}

