}

/* ===== Bottom Sheet (Item Detail) ===== */
.bs-overlay-item {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(16px);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  animation: bsFadeIn 300ms ease-out;
}

@keyframes bsFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.bs-sheet-item {
  position: relative;
  background: linear-gradient(180deg,
    rgba(220, 240, 250, 0.95) 0%,
    rgba(200, 230, 245, 0.95) 100%);
  backdrop-filter: blur(30px) saturate(160%);
  border-radius: 32px 32px 0 0;
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-bottom: none;
  height: 70vh;
  max-height: 70vh;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 -8px 40px rgba(80, 140, 180, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.7);
  transform: translateY(100%);
  transition: transform 400ms cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.bs-sheet-item::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    135deg,
    transparent 30%,
    rgba(255, 255, 255, 0.1) 45%,
    rgba(255, 255, 255, 0.25) 50%,
    rgba(255, 255, 255, 0.1) 55%,
    transparent 70%
  );
  animation: liquidShine 8s ease-in-out infinite;
  pointer-events: none;
  z-index: 1;
}

.bs-sheet-item.bs-sheet-visible {
  transform: translateY(0);
}

.bs-drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 0 8px;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.bs-drag-bar {
  width: 40px;
  height: 5px;
  border-radius: 9999px;
  background: rgba(80, 140, 180, 0.25);
  box-shadow: inset 1px 1px 2px rgba(0, 0, 0, 0.05), inset -1px -1px 2px rgba(255, 255, 255, 0.5);
}

.bs-header {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 16px 12px;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.bs-header-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(12px);
  box-shadow:
    3px 3px 8px rgba(80, 140, 180, 0.15),
    -2px -2px 6px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.bs-header-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.5) 0%,
    transparent 50%,
    rgba(255, 255, 255, 0.3) 100%);
  pointer-events: none;
}

.bs-header-btn:active {
  transform: scale(0.95);
  box-shadow: inset 2px 2px 5px rgba(80, 140, 180, 0.1), inset -2px -2px 5px rgba(255, 255, 255, 0.3);
}

.bs-header-btn-icon {
  font-size: 16px;
  color: #4a7a8a;
  line-height: 1;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.bs-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 20px;
  position: relative;
  z-index: 2;
}

.bs-sheet-item .bs-photo-wrap {
  position: relative;
  margin-bottom: 16px;
}

.bs-sheet-item .bs-photo-carousel {
  width: 100%;
  margin: 0;
  height: 220px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow:
    0 8px 24px rgba(80, 140, 180, 0.2),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
}

.bs-sheet-item .bs-photo-img {
  width: 100%;
  height: 220px;
  display: block;
  object-fit: cover;
}

.bs-info-area {
  margin-bottom: 14px;
}

.bs-title {
  font-size: 20px;
  font-weight: 700;
  color: #1a3a4a;
  display: block;
  margin-bottom: 6px;
  letter-spacing: 0.3px;
}

.bs-desc {
  font-size: 13px;
  color: #4a7a8a;
  line-height: 1.5;
  display: block;
}

.bs-tags-area {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.bs-tag-pill {
  padding: 6px 14px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(8px);
  box-shadow:
    2px 2px 6px rgba(80, 140, 180, 0.1),
    -1px -1px 4px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-tag-text {
  font-size: 12px;
  color: #3a6a7a;
  font-weight: 500;
}

.bs-colors-area {
  margin-bottom: 16px;
}

.bs-colors-label {
  font-size: 13px;
  color: #4a7a8a;
  margin-bottom: 10px;
  display: block;
  font-weight: 600;
}

.bs-colors-row {
  display: flex;
  gap: 10px;
}

.bs-color-dot {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  box-shadow:
    2px 2px 6px rgba(0, 0, 0, 0.1),
    -1px -1px 4px rgba(255, 255, 255, 0.5),
    inset 0 1px 2px rgba(255, 255, 255, 0.3);
  border: 2px solid rgba(255, 255, 255, 0.6);
}

.bs-location-area {
  margin-bottom: 16px;
}

.bs-location-label-text {
  font-size: 13px;
  color: #4a7a8a;
  margin-bottom: 10px;
  display: block;
  font-weight: 600;
}

.bs-location-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.bs-location-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 9999px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(8px);
  box-shadow:
    2px 2px 6px rgba(80, 140, 180, 0.1),
    -1px -1px 4px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-location-pill-label {
  font-size: 11px;
  color: #5a9a9a;
  font-weight: 500;
}

.bs-location-pill-value {
  font-size: 13px;
  color: #1a3a4a;
  font-weight: 600;
}

.bs-action-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 20px calc(14px + env(safe-area-inset-bottom));
  background: linear-gradient(180deg,
    rgba(220, 240, 250, 0.9),
    rgba(200, 230, 245, 0.9));
  flex-shrink: 0;
  box-shadow: 0 -4px 20px rgba(80, 140, 180, 0.12);
  border-top: 1px solid rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 2;
}

.bs-close-btn {
  flex: 1;
  height: 48px;
  border-radius: 16px;
  background: linear-gradient(145deg,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.2) 100%);
  backdrop-filter: blur(12px);
  box-shadow:
    3px 3px 8px rgba(80, 140, 180, 0.12),
    -2px -2px 6px rgba(255, 255, 255, 0.25),
    inset 0 1px 1px rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.bs-close-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 16px;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.5) 0%,
    transparent 40%,
    transparent 60%,
    rgba(255, 255, 255, 0.3) 100%);
  pointer-events: none;
}

.bs-close-btn:active {
  transform: scale(0.97);
  box-shadow: inset 2px 2px 5px rgba(80, 140, 180, 0.1), inset -2px -2px 5px rgba(255, 255, 255, 0.3);
}

.bs-close-text {
  font-size: 15px;
  font-weight: 600;
  color: #1a3a4a;
  position: relative;
  z-index: 1;
}
