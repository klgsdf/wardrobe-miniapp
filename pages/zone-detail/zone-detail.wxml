<view class="zone-page" data-theme="{{__theme}}">
  <!-- Safe Area Header -->
  <view class="safe-header">
    <view class="header-inner">
      <view class="back-btn" bindtap="navigateBack">
        <image src="/images/icon-back.png" class="back-icon" />
        <text class="back-text">返回</text>
      </view>
      <text class="header-title">{{zoneName}}</text>
      <view class="header-placeholder"></view>
    </view>
  </view>

  <!-- Zone info card -->
  <view class="zone-info-wrapper">
    <view class="card zone-info-card">
      <view class="zone-icon-box">
        <image src="/images/grid.png" class="zone-icon" style="filter: var(--icon-filter-accent);" />
      </view>
      <view class="zone-meta">
        <text class="zone-name">{{zoneName}}</text>
        <text class="zone-type-text">{{zoneDesc}}</text>
        <text class="zone-wardrobe">所属衣柜：{{wardrobeName}}</text>
      </view>
      <view class="zone-count-box">
        <text class="zone-count">{{itemCount}}</text>
        <text class="zone-count-label">件</text>
      </view>
    </view>
  </view>

  <!-- Empty state -->
  <block wx:if="{{zoneItems.length === 0}}">
    <view class="empty-section">
      <view class="card-inset empty-card">
        <image src="/images/shirt.png" class="empty-icon" style="filter: var(--icon-filter-accent);" />
        <text class="empty-title">还没有衣物</text>
        <text class="empty-desc">去「衣物」页面添加衣物并分配到此分区</text>
      </view>
    </view>
  </block>

  <!-- Zone items - Masonry Grid -->
  <block wx:if="{{zoneItems.length > 0}}">
    <view class="items-section">
      <view class="section-header">
        <view class="section-dot"></view>
        <text class="section-title">分区衣物</text>
        <text class="section-count">({{zoneItems.length}} 件)</text>
      </view>

      <view class="masonry px-0 mt-3">
        <view class="masonry-col">
          <view wx:for="{{masonryLeft}}" wx:key="id" class="masonry-item" bindlongpress="showItemDetail" data-id="{{item.id}}">
            <image class="masonry-img" src="{{item.image}}" mode="widthFix" />
            <view class="p-2">
              <text class="text-12px font-medium block truncate">{{item.name}}</text>
              <text class="text-10px" style="color: var(--text-muted);">{{item.category}} · {{item.style}}</text>
            </view>
          </view>
        </view>
        <view class="masonry-col">
          <view wx:for="{{masonryRight}}" wx:key="id" class="masonry-item" bindlongpress="showItemDetail" data-id="{{item.id}}">
            <image class="masonry-img" src="{{item.image}}" mode="widthFix" />
            <view class="p-2">
              <text class="text-12px font-medium block truncate">{{item.name}}</text>
              <text class="text-10px" style="color: var(--text-muted);">{{item.category}} · {{item.style}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- Item Detail Bottom Sheet -->
  <view wx:if="{{showItemDetailSheet}}" class="bs-overlay-item" bindtap="hideItemDetail">
    <view class="bs-sheet bs-sheet-item {{showItemDetailSheet ? 'bs-sheet-visible' : ''}}" catchtap="preventBubble">
      <!-- Header -->
      <view class="bs-header">
        <view bindtap="hideItemDetail" class="bs-header-btn">
          <text class="bs-header-btn-icon">✕</text>
        </view>
      </view>

      <!-- Content -->
      <scroll-view class="bs-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <!-- Photo -->
        <view class="bs-photo-wrap" wx:if="{{detailItem}}">
          <view class="bs-photo-carousel">
            <image class="bs-photo-img" src="{{detailItem.image}}" mode="aspectFill" />
          </view>
        </view>

        <!-- Info -->
        <view class="bs-info-area" wx:if="{{detailItem}}">
          <text class="bs-title">{{detailItem.name}}</text>
          <text class="bs-desc">{{detailItem.category}} · {{detailItem.subCategory || detailItem.subcategory || ''}} · {{detailItem.style}}</text>
        </view>

        <!-- Tags -->
        <view class="bs-tags-area" wx:if="{{detailItem}}">
          <view class="bs-tag-pill" wx:for="{{detailItem.seasons}}" wx:key="*this">
            <text class="bs-tag-text">{{item}}</text>
          </view>
        </view>

        <!-- Colors -->
        <view class="bs-colors-area" wx:if="{{detailItem && detailItem.colors}}">
          <text class="bs-colors-label">颜色</text>
          <view class="bs-colors-row">
            <view wx:for="{{detailItem.colors}}" wx:key="*this" class="bs-color-dot" style="background: {{item}};"></view>
          </view>
        </view>

        <!-- Location -->
        <view class="bs-location-area" wx:if="{{detailItem}}">
          <view class="bs-location-label-text">位置信息</view>
          <view class="bs-location-pills">
            <view class="bs-location-pill">
              <text class="bs-location-pill-label">衣柜</text>
              <text class="bs-location-pill-value">{{detailWardrobeName}}</text>
            </view>
            <view class="bs-location-pill">
              <text class="bs-location-pill-label">分区</text>
              <text class="bs-location-pill-value">{{detailZoneName}}</text>
            </view>
          </view>
        </view>

        <view style="height: 20px;"></view>
      </scroll-view>

      <!-- Bottom Actions -->
      <view class="bs-action-bar">
        <view class="bs-edit-btn" bindtap="editItemDetail">
          <text class="bs-edit-icon">✎</text>
          <text class="bs-edit-text">编辑</text>
        </view>
        <view class="bs-delete-btn" bindtap="deleteItemDetail">
          <text class="bs-delete-icon">🗑</text>
          <text class="bs-delete-text">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>
