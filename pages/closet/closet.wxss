.closet-page {
  min-height: 100vh;
  padding-bottom: calc(80px + env(safe-area-inset-bottom));
}

.stats-bar {
  display: flex;
  padding: 16px 0;
}

.stat-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 0;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  border-radius: var(--border-radius);
  border: 2px dashed var(--border);
  background: var(--card-bg);
  box-shadow: inset 3px 3px 8px var(--shadow-inset-dark), inset -3px -3px 8px var(--shadow-inset-light);
}

.wardrobe-item {
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.mb-3 {
  margin-bottom: 12px;
}

.icon-box {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft);
  flex-shrink: 0;
}

.icon-box-img {
  width: 20px;
  height: 20px;
}

.wardrobe-arrow {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.dialog-box {
  background: var(--bg);
  border-radius: var(--border-radius);
  padding: 20px;
  max-width: 300px;
  box-shadow: 12px 12px 30px var(--shadow-dark), -8px -8px 30px var(--shadow-light);
  position: relative;
  z-index: 10;
}

.form-input {
  width: 100%;
  height: 44px;
  padding: 0 14px;
  border-radius: 10px;
  background: var(--bg);
  box-shadow: inset 3px 3px 8px var(--shadow-inset-dark), inset -3px -3px 8px var(--shadow-inset-light);
  font-size: 14px;
  color: var(--text-primary);
  box-sizing: border-box;
  line-height: 44px;
}

.btn-sm {
  height: 32px;
  border-radius: 8px;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel {
  background: var(--card-bg);
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--accent);
  color: white;
}
