.closet-page {
  min-height: 100vh;
  padding-bottom: calc(80px + env(safe-area-inset-bottom));
  background: var(--bg);
}

.page-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* ===== Glass Panel (from add-clothes) ===== */
.glass-panel {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.6);
  border-radius: 16px;
}

.stats-bar {
  display: flex;
  padding: 16px 0;
}

.stat-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 0;
}

.stats-divider {
  width: 1px;
  background: linear-gradient(to bottom, transparent, var(--border), transparent);
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px;
  border-radius: 14px;
  border: 1.5px dashed rgba(160, 148, 134, 0.25);
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  gap: 8px;
  transition: all 0.2s ease;
}

.add-btn:active {
  background: rgba(255, 255, 255, 0.55);
  transform: scale(0.98);
}

.add-btn-icon {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.add-btn-text {
  font-size: 14px;
  font-weight: 500;
  color: var(--accent);
}

.wardrobe-item {
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

.wardrobe-item:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.7);
}

.mb-3 {
  margin-bottom: 12px;
}

.icon-box {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft);
  flex-shrink: 0;
}

.icon-box-img {
  width: 20px;
  height: 20px;
}

.wardrobe-arrow {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  opacity: 0.4;
}

/* ===== Bottom Sheet (from add-clothes) ===== */
.sheet-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
}

.sheet-panel {
  width: 100%;
  max-width: 560px;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-radius: 28px 28px 0 0;
  border: 1px solid rgba(255, 255, 255, 0.55);
  box-shadow: 0 -8px 40px rgba(0, 0, 0, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.8);
  overflow: hidden;
  box-sizing: border-box;
  animation: sheetSlideUp 0.35s cubic-bezier(0.32, 0.72, 0, 1) forwards;
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes sheetSlideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.sheet-handle {
  width: 36px;
  height: 4px;
  border-radius: 2px;
  background: rgba(0, 0, 0, 0.15);
  margin: 10px auto 6px;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 20px 12px 20px;
}

.sheet-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.sheet-close {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.sheet-close:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.3);
}

.sheet-body {
  padding: 0 20px 20px 20px;
}

.field-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8px;
  letter-spacing: 0.01em;
}

.glass-input {
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.35);
  box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.03);
  font-size: 15px;
  color: var(--text-primary);
  box-sizing: border-box;
  outline: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-input:focus {
  background: rgba(255, 255, 255, 0.7);
  border-color: rgba(0, 0, 0, 0.08);
  box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.03), 0 0 0 3px var(--accent-soft);
}

.input-placeholder {
  color: var(--text-muted);
  font-size: 14px;
}

.mb-3 {
  margin-bottom: 12px;
}

.mb-4 {
  margin-bottom: 16px;
}

.btn-gradient {
  width: 100%;
  height: 48px;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-coral) 100%);
  color: white;
  font-size: 15px;
  font-weight: 600;
  border: none;
  box-shadow: 0 4px 14px var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-gradient::after {
  border: none;
}

.btn-gradient:active {
  transform: scale(0.96);
  box-shadow: 0 2px 8px var(--accent-soft);
}

.btn-gradient-sm {
  height: 46px;
  font-size: 15px;
}
