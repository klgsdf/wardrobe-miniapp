<view class="container closet-page" data-theme="{{__theme}}">
  <!-- Header -->
  <view class="safe-top px-4 pb-2" style="padding-top: 54px;">
    <text class="page-title">我的衣柜</text>
  </view>

  <!-- Stats Bar -->
  <view class="glass-panel stats-bar mx-4 mt-2">
    <view class="stat-col">
      <text class="text-stat">{{totalWardrobes}}</text>
      <text class="text-stat-label mt-1">个衣柜</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stat-col">
      <text class="text-stat">{{totalItems}}</text>
      <text class="text-stat-label mt-1">件衣物</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stat-col">
      <text class="text-stat">{{totalZones}}</text>
      <text class="text-stat-label mt-1">个分区</text>
    </view>
  </view>

  <!-- Add Button -->
  <view class="mx-4 mt-4">
    <view class="add-btn" bindtap="showAdd">
      <view class="add-btn-icon">+</view>
      <text class="add-btn-text">添加衣柜</text>
    </view>
  </view>

  <!-- Wardrobe List -->
  <view class="mx-4 mt-4">
    <view wx:for="{{wardrobes}}" wx:key="id" class="glass-panel wardrobe-item mb-3" bindtap="goToDetail" data-id="{{item.id}}" bindlongpress="onWardrobeLongPress" data-wardrobe-id="{{item.id}}" data-wardrobe-name="{{item.name}}">
      <view class="icon-box">
        <image src="/images/layout-grid.png" class="icon-box-img" />
      </view>
      <view class="flex-1 min-w-0">
        <text class="text-body font-medium block truncate">{{item.name}}</text>
        <text class="text-caption block">{{item.description}}</text>
        <text class="text-caption block" style="color: var(--text-muted);">{{item.zoneCount}}个分区 · {{item.itemCount}}件衣物</text>
      </view>
      <image src="/images/chevron-right.png" class="wardrobe-arrow" />
    </view>
  </view>

  <!-- Add Dialog (Bottom Sheet) -->
  <view wx:if="{{showAddDialog}}" class="sheet-overlay" catchtouchmove="prevent">
    <view class="sheet-panel" catchtap="preventBubble">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">添加衣柜</text>
        <view bindtap="hideAdd" class="sheet-close">
          <text style="color: var(--text-muted); font-size: 18px; line-height: 1;">×</text>
        </view>
      </view>
      <view class="sheet-body">
        <text class="field-label">衣柜名称</text>
        <input class="glass-input mb-3" value="{{newName}}" bindinput="onNameInput" placeholder="给衣柜起个名字" placeholder-class="input-placeholder" />
        <text class="field-label">描述（可选）</text>
        <input class="glass-input mb-4" value="{{newDesc}}" bindinput="onDescInput" placeholder="简短描述" placeholder-class="input-placeholder" />
        <button class="btn-gradient btn-gradient-sm" bindtap="confirmAdd">确认添加</button>
      </view>
    </view>
  </view>

  <!-- Edit Wardrobe Name Dialog -->
  <view wx:if="{{showEditDialog}}" class="sheet-overlay" catchtouchmove="prevent">
    <view class="sheet-panel" catchtap="preventBubble">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">编辑衣柜名称</text>
        <view bindtap="hideEditDialog" class="sheet-close">
          <text style="color: var(--text-muted); font-size: 18px; line-height: 1;">×</text>
        </view>
      </view>
      <view class="sheet-body">
        <text class="field-label">衣柜名称</text>
        <input class="glass-input mb-4" value="{{editNameValue}}" bindinput="onEditNameInput" placeholder="请输入新名称" placeholder-class="input-placeholder" />
        <button class="btn-gradient btn-gradient-sm" bindtap="confirmEditWardrobeName">确认修改</button>
      </view>
    </view>
  </view>
</view>
