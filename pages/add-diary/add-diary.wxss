.add-diary-page { min-height: 100vh; background: var(--bg); padding-bottom: calc(24px + env(safe-area-inset-bottom)); }

/* ===== Safe Area Header ===== */
.safe-header {
  padding-top: 54px;
  background: var(--bg);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 50px;
  padding: 0 16px;
  margin: 0 12px;
}

.header-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
  text-align: center;
  flex: 1;
}

.header-placeholder {
  min-width: 60px;
}
.form-input { width: 100%; padding: 10px 14px; border-radius: 10px; background: var(--bg); box-shadow: inset 4px 4px 10px var(--shadow-inset-dark), inset -4px -4px 10px var(--shadow-inset-light); font-size: 14px; color: var(--text-primary); box-sizing: border-box; }
.style-pill { padding: 8px 16px; border-radius: 12px; font-size: 13px; color: var(--text-muted); background: var(--bg); box-shadow: inset 2px 2px 5px var(--shadow-inset-dark), inset -2px -2px 5px var(--shadow-inset-light); }
.style-pill-active { color: var(--accent); background: var(--accent-soft); box-shadow: 3px 3px 8px var(--shadow-dark), -3px -3px 8px var(--shadow-light); font-weight: 600; }
.bottom-sheet { background: var(--card-bg, var(--bg)); border-radius: 28px; padding: 20px 12px 40px 12px; position: relative; z-index: 10; width: 92vw; max-width: 560px; margin: 0 auto calc(24px + env(safe-area-inset-bottom)) auto; border: 1px solid rgba(255, 255, 255, 0.5); box-shadow: 0 -12px 48px var(--shadow-dark), 0 -4px 16px var(--shadow-dark), 0 -1px 4px var(--shadow-dark), inset 0 1px 0 rgba(255, 255, 255, 0.6); }
.grid-cols-2 { display: flex; flex-wrap: wrap; }
.grid-cols-2 > view { width: 48%; margin-right: 4%; margin-bottom: 8px; }
.item-card { border-radius: 12px; overflow: hidden; position: relative; box-shadow: 3px 3px 8px var(--shadow-dark), -3px -3px 8px var(--shadow-light); }
.item-card-selected { box-shadow: 0 0 0 2px var(--accent), 3px 3px 8px var(--shadow-dark); }
.aspect-square { width: 100%; height: 0; padding-bottom: 100%; }
.object-cover { object-fit: cover; }
.absolute { position: absolute; }
.btn-cancel { height: 44px; border-radius: 12px; background: var(--card-bg); color: var(--text-secondary); font-size: 14px; border: none; box-shadow: 4px 4px 10px var(--shadow-dark); }
.btn-confirm { height: 44px; border-radius: 12px; background: var(--accent); color: white; font-size: 14px; font-weight: 500; border: none; box-shadow: 4px 4px 12px var(--shadow-dark); }

/* Font size utilities */
.text-10px { font-size: 10px; }
