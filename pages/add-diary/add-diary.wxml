<view class="container add-diary-page" data-theme="{{__theme}}">
  <!-- Glass Navigation Header -->
  <view class="glass-nav">
    <view class="nav-inner">
      <view bindtap="cancel" class="nav-back">
        <image src="/images/icon-back.png" class="nav-back-icon" />
      </view>
      <text class="nav-title">添加穿搭</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <scroll-view scroll-y class="form-scroll" style="height: calc(100vh - 94px - 90px); margin-top: 4px;" enhanced show-scrollbar="{{false}}">
    <!-- Photos Area -->
    <view class="glass-panel photo-panel" style="animation-delay: 0ms;">
      <text class="field-label">搭配照片 <text class="field-label-hint" wx:if="{{photos.length > 0}}">· {{photos.length}}/3</text></text>
      <!-- Has photos: grid -->
      <view wx:if="{{photos.length > 0}}" class="photo-grid">
        <view wx:for="{{photos}}" wx:key="*this" class="photo-thumb-wrap">
          <image class="photo-thumb" src="{{item}}" mode="aspectFill" />
          <view bindtap="removePhoto" data-idx="{{index}}" class="photo-thumb-remove">
            <text class="photo-thumb-remove-x">×</text>
          </view>
        </view>
        <view wx:if="{{photos.length < 3}}" bindtap="choosePhoto" class="photo-add-btn">
          <text class="photo-add-icon">+</text>
        </view>
      </view>
      <!-- Empty state -->
      <view wx:else bindtap="choosePhoto" class="photo-upload-empty">
        <view class="photo-upload-icon-wrap">
          <image src="/images/shirt.png" class="photo-upload-icon" />
        </view>
        <text class="photo-upload-title">上传照片（最多3张）</text>
      </view>
    </view>

    <!-- Name -->
    <view class="glass-panel field-panel compact" style="animation-delay: 50ms;">
      <text class="field-label">搭配名称</text>
      <input class="glass-input compact-input" value="{{name}}" bindinput="onNameInput" placeholder="给这套搭配起个名字" placeholder-class="input-placeholder" />
    </view>

    <!-- Style -->
    <view class="glass-panel field-panel compact" style="animation-delay: 100ms;">
      <text class="field-label">风格标签</text>
      <view class="tag-wrap compact-tags">
        <view wx:for="{{styleOptions}}" wx:key="*this" bindtap="selectStyle" data-s="{{item}}" class="tag-pill {{style === item ? 'tag-pill-active' : ''}}">{{item}}</view>
      </view>
    </view>

    <!-- Note -->
    <view class="glass-panel field-panel compact" style="animation-delay: 150ms;">
      <text class="field-label">备注 <text class="field-label-hint">选填</text></text>
      <textarea class="glass-textarea compact-textarea" value="{{note}}" bindinput="onNoteInput" placeholder="记录心情、场合…" placeholder-class="input-placeholder" maxlength="200" />
    </view>

    <!-- Items -->
    <view class="glass-panel field-panel compact" style="animation-delay: 200ms;">
      <text class="field-label">关联单品 <text class="field-label-hint" wx:if="{{selectedItemNames.length > 0}}">· {{selectedItemNames.length}}</text></text>
      <!-- 已选单品列表 -->
      <view wx:if="{{selectedItems.length > 0}}" class="selected-items-list">
        <view wx:for="{{selectedItems}}" wx:key="id" class="selected-item-tag">
          <text class="selected-item-name">{{item.name}}</text>
          <text class="selected-item-category">{{item.category}}</text>
          <view bindtap="removeSelectedItem" data-id="{{item.id}}" class="selected-item-remove">
            <text class="selected-item-remove-x">×</text>
          </view>
        </view>
      </view>
      <view bindtap="toggleItemPicker" class="glass-dropdown compact-dropdown">
        <text class="dropdown-text {{selectedItemNames.length > 0 ? 'dropdown-text-active' : ''}}">{{selectedItemNames.length > 0 ? '继续添加单品…' : '点击添加单品…'}}</text>
        <image src="/images/chevron-down.png" class="dropdown-arrow" />
      </view>
    </view>

    <!-- Bottom spacing -->
    <view style="height: 80px;"></view>
  </scroll-view>

  <!-- Fixed Bottom Confirm Button -->
  <view class="bottom-bar">
    <button class="btn-gradient" bindtap="submit">
      <text>确认添加</text>
    </button>
  </view>

  <!-- ===== Bottom Sheet: Item Picker ===== -->
  <view wx:if="{{showItemPicker}}" class="sheet-overlay" bindtap="toggleItemPicker">
    <view class="sheet-panel" catchtap="preventBubble">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">选择单品</text>
        <view bindtap="toggleItemPicker" class="sheet-close">
          <text style="color: var(--text-muted); font-size: 18px; line-height: 1;">×</text>
        </view>
      </view>
      <view class="sheet-body">
        <!-- Search -->
        <view class="item-picker-search">
          <text class="item-picker-search-icon">🔍</text>
          <input class="item-picker-search-input" placeholder="搜索衣物…" value="{{itemSearchQuery}}" bindinput="onItemSearch" />
        </view>
        <!-- Empty -->
        <view wx:if="{{itemPickerList.length === 0}}" class="item-picker-empty">
          <text class="item-picker-empty-icon">👕</text>
          <text class="item-picker-empty-text">暂无衣物</text>
        </view>
        <!-- Grid -->
        <view wx:else class="item-picker-grid">
          <view wx:for="{{itemPickerList}}" wx:key="id" bindtap="toggleItem" data-id="{{item.id}}" class="item-picker-card {{item.selected ? 'item-picker-card-selected' : ''}}">
            <view class="item-picker-img-wrap">
              <image class="item-picker-img" src="{{item.image}}" mode="aspectFill" />
            </view>
            <view class="item-picker-info">
              <text class="item-picker-name">{{item.name}}</text>
              <view class="item-picker-meta">
                <text class="item-picker-category">{{item.category}}</text>
                <text wx:if="{{item.subCategory}}" class="item-picker-subcategory">{{item.subCategory}}</text>
              </view>
            </view>
            <view wx:if="{{item.selected}}" class="item-picker-check">
              <text style="color: white; font-size: 10px;">✓</text>
            </view>
          </view>
        </view>
      </view>
      <view class="sheet-footer">
        <button class="btn-gradient btn-gradient-sm" bindtap="toggleItemPicker">完成 {{selectedItemNames.length > 0 ? '(' + selectedItemNames.length + ')' : ''}}</button>
      </view>
    </view>
  </view>

  <!-- ===== Image Cropper Overlay ===== -->
  <view wx:if="{{showCropper}}" class="cropper-overlay">
    <view class="cropper-header">
      <view bindtap="cancelCrop" class="cropper-back">
        <text class="cropper-back-x">×</text>
      </view>
      <text class="cropper-title">裁剪照片</text>
      <view bindtap="confirmCrop" class="cropper-done">
        <text class="cropper-done-text">完成</text>
      </view>
    </view>
    <view class="cropper-body">
      <view class="cropper-container" style="height: {{cropContainerH}}px;"
            catchtouchstart="onCropTouchStart"
            catchtouchmove="onCropTouchMove"
            catchtouchend="onCropTouchEnd">
        <image class="cropper-bg-image" src="{{cropSrc}}" style="width: {{cropImgW}}px; height: {{cropImgH}}px; left: {{cropImgX}}px; top: {{cropImgY}}px;" />
        <view class="cropper-frame" style="width: {{cropFrameW}}px; height: {{cropFrameH}}px; left: {{cropFrameX}}px; top: {{cropFrameY}}px;">
          <view class="cropper-corner cropper-corner-tl"></view>
          <view class="cropper-corner cropper-corner-tr"></view>
          <view class="cropper-corner cropper-corner-bl"></view>
          <view class="cropper-corner cropper-corner-br"></view>
          <view class="cropper-grid-h"></view>
          <view class="cropper-grid-v"></view>
          <view class="cropper-edge cropper-edge-t" data-edge="t"></view>
          <view class="cropper-edge cropper-edge-r" data-edge="r"></view>
          <view class="cropper-edge cropper-edge-b" data-edge="b"></view>
          <view class="cropper-edge cropper-edge-l" data-edge="l"></view>
          <view class="cropper-handle cropper-handle-tl" data-handle="tl"></view>
          <view class="cropper-handle cropper-handle-tr" data-handle="tr"></view>
          <view class="cropper-handle cropper-handle-bl" data-handle="bl"></view>
          <view class="cropper-handle cropper-handle-br" data-handle="br"></view>
        </view>
      </view>
      <view class="cropper-hint-row">
        <text class="cropper-hint">拖动移动，捏合缩放，拖边调整</text>
      </view>
    </view>
  </view>

  <!-- Hidden canvas for image cropping -->
  <canvas canvas-id="diaryCropCanvas" class="crop-canvas"></canvas>
</view>
