<view class="container add-diary-page" data-theme="{{__theme}}">
  <view class="safe-header">
    <view class="header-inner">
      <view bindtap="cancel" class="w-9 h-9 rounded-full flex items-center justify-center" style="background: var(--bg); box-shadow: 4px 4px 10px var(--shadow-dark);"><text style="color: var(--text-primary); font-size: 18px;">&lt;</text></view>
      <text class="header-title">添加日记</text>
      <view class="header-placeholder"></view>
    </view>
  </view>
  <scroll-view scroll-y class="flex-1 px-4 pb-6" style="height: calc(100vh - 94px);">
    <!-- Photos -->
    <view class="mb-4">
      <text class="text-caption block mb-2" style="color: var(--text-secondary);">搭配照片 {{photos.length > 0 ? '(' + photos.length + '/3)' : ''}}</text>
      <view wx:if="{{photos.length === 0}}" bindtap="choosePhoto" class="w-full rounded-2xl flex flex-col items-center justify-center gap-3" style="height: 200px; border: 2px dashed var(--border); background: var(--card-bg); box-shadow: inset 3px 3px 8px var(--shadow-inset-dark);">
        <text style="color: var(--accent); font-size: 24px;">📷</text>
        <text class="text-caption" style="color: var(--text-muted);">点击添加照片（最多3张）</text>
      </view>
      <view wx:else>
        <view class="relative w-full rounded-2xl overflow-hidden mb-2" style="height: 220px; box-shadow: 4px 4px 12px var(--shadow-dark);">
          <image class="w-full h-full object-cover" src="{{photos[0]}}" mode="aspectFill" />
          <view bindtap="removePhoto" data-idx="0" class="absolute top-2 right-2 w-7 h-7 rounded-full flex items-center justify-center" style="background: rgba(0,0,0,0.55);"><text style="color: white; font-size: 12px;">×</text></view>
          <view class="absolute top-2 left-2 px-2 py-0_5 rounded-full text-10px" style="background: rgba(0,0,0,0.5); color: white;">1 / {{photos.length}}</view>
        </view>
        <view wx:if="{{photos.length < 3}}" bindtap="choosePhoto" class="w-16 h-16 rounded-xl flex items-center justify-center" style="border: 2px dashed var(--border); background: var(--card-bg); box-shadow: inset 2px 2px 6px var(--shadow-inset-dark);"><text style="color: var(--text-muted); font-size: 18px;">+</text></view>
      </view>
    </view>
    <!-- Name -->
    <view class="mb-4">
      <text class="text-caption block mb-1" style="color: var(--text-secondary);">搭配名称</text>
      <input class="form-input" value="{{name}}" bindinput="onNameInput" placeholder="给这套搭配起个名字" />
    </view>
    <!-- Style -->
    <view class="mb-4">
      <text class="text-caption block mb-1" style="color: var(--text-secondary);">风格标签</text>
      <view class="flex flex-wrap gap-2">
        <view wx:for="{{styleOptions}}" wx:key="*this" bindtap="selectStyle" data-s="{{item}}" class="style-pill {{style === item ? 'style-pill-active' : ''}}">{{item}}</view>
      </view>
    </view>
    <!-- Note -->
    <view class="mb-4">
      <text class="text-caption block mb-1" style="color: var(--text-secondary);">备注</text>
      <textarea class="form-input" value="{{note}}" bindinput="onNoteInput" placeholder="记录心情、场合..." rows="3" />
    </view>
    <!-- Items -->
    <view class="mb-4">
      <text class="text-caption block mb-1" style="color: var(--text-secondary);">单品 {{selectedItemNames.length > 0 ? '(' + selectedItemNames.length + ')' : ''}}</text>
      <view bindtap="toggleItemPicker" class="form-input">
        <text wx:if="{{selectedItemNames.length === 0}}" style="color: var(--text-muted);">点击添加单品...</text>
        <view wx:else class="flex flex-wrap gap-2">
          <text wx:for="{{selectedItemNames}}" wx:key="*this" class="pill">{{item}}</text>
        </view>
      </view>
    </view>
    <!-- Buttons -->
    <view class="flex gap-3 mt-6">
      <button class="btn-cancel flex-1" bindtap="cancel">取消</button>
      <button class="btn-confirm flex-1" bindtap="submit">确认</button>
    </view>
  </scroll-view>

  <!-- Item Picker -->
  <view wx:if="{{showItemPicker}}" class="overlay flex items-end justify-center">
    <view class="bottom-sheet w-full" catchtap="preventBubble">
      <view class="flex items-center justify-between mb-3">
        <text class="text-heading">选择单品</text>
        <view bindtap="toggleItemPicker" class="w-7 h-7 rounded-full flex items-center justify-center" style="background: var(--card-bg); box-shadow: 3px 3px 8px var(--shadow-dark);"><text style="color: var(--text-muted); font-size: 12px;">×</text></view>
      </view>
      <view class="relative mb-3 rounded-xl flex items-center px-3 py-2" style="background: var(--bg); box-shadow: inset 3px 3px 8px var(--shadow-inset-dark);">
        <text style="color: var(--text-muted); margin-right: 6px;">🔍</text>
        <input class="flex-1 text-body" style="color: var(--text-primary);" placeholder="搜索衣物..." value="{{itemSearchQuery}}" bindinput="onItemSearch" />
      </view>
      <view wx:if="{{itemPickerList.length === 0}}" class="text-center py-8">
        <text style="font-size: 24px; color: var(--accent);">👕</text>
        <text class="text-body block" style="color: var(--text-muted);">暂无衣物</text>
      </view>
      <view wx:else class="grid grid-cols-2 gap-2">
        <view wx:for="{{itemPickerList}}" wx:key="id" bindtap="toggleItem" data-id="{{item.id}}" class="item-card {{item.selected ? 'item-card-selected' : ''}}">
          <view class="w-full aspect-square overflow-hidden"><image class="w-full h-full object-cover" src="{{item.image}}" mode="aspectFill" /></view>
          <view class="px-2 py-2" style="background: {{item.selected ? 'var(--accent-soft)' : 'var(--card-bg)'}};">
            <text class="text-10px font-medium truncate block" style="color: {{item.selected ? 'var(--accent)' : 'var(--text-primary)'}};">{{item.name}}</text>
          </view>
          <view wx:if="{{item.selected}}" class="absolute top-2 right-2 w-6 h-6 rounded-full flex items-center justify-center" style="background: var(--accent);"><text style="color: white; font-size: 10px;">√</text></view>
        </view>
      </view>
      <button class="btn-confirm w-full mt-4" bindtap="toggleItemPicker">完成 {{selectedItemNames.length > 0 ? '(' + selectedItemNames.length + ')' : ''}}</button>
    </view>
  </view>
</view>
