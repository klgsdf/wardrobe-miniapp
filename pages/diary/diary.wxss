/* ===== Item Detail Modal (Center) ===== */
.bs-sheet-item {
  background: var(--card-bg);
  border-radius: 28px;
  border: 1px solid rgba(255, 255, 255, 0.6);
  height: 65vh;
  max-height: 65vh;
  width: 84vw;
  max-width: 480px;
  margin: 0 auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15);
  transform: scale(0.9);
  opacity: 0;
  transition: all 400ms cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.bs-sheet-item.bs-sheet-visible {
  transform: scale(1);
  opacity: 1;
}

.bs-drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 0 8px;
  flex-shrink: 0;
}

.bs-drag-bar {
  width: 44px;
  height: 5px;
  border-radius: 9999px;
  background: var(--text-muted);
  box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1), inset -1px -1px 2px rgba(255,255,255,0.5);
}

.bs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px 12px;
  flex-shrink: 0;
}

.bs-header-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 6px 6px 12px var(--shadow-dark), -6px -6px 12px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bs-header-btn:active {
  transform: scale(0.95);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-header-btn-icon {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1;
  font-weight: 500;
}

.bs-scroll {
  height: calc(78vh - 150px);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 16px;
}

.bs-sheet-item .bs-photo-wrap {
  position: relative;
  margin-bottom: 16px;
}

.bs-sheet-item .bs-photo-carousel {
  width: 100%;
  margin: 0;
  height: calc(72vw * 9 / 16);
  max-height: calc(420px * 9 / 16);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 4px 4px 12px var(--shadow-dark), -2px -2px 8px var(--shadow-light);
}

.bs-sheet-item .bs-photo-img {
  width: 100%;
  height: calc(72vw * 9 / 16);
  max-height: calc(420px * 9 / 16);
  display: block;
  object-fit: cover;
}

.bs-info-area {
  margin-bottom: 12px;
}

.bs-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.2px;
}

.bs-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
  display: block;
}

.bs-tags-area {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 16px;
}

.bs-tag-pill {
  padding: 4px 10px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-tag-text {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-colors-area {
  margin-bottom: 16px;
}

.bs-colors-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

.bs-colors-row {
  display: flex;
  gap: 10px;
}

.bs-color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  box-shadow: 3px 3px 8px rgba(0,0,0,0.15), -2px -2px 6px rgba(255,255,255,0.6), inset 0 1px 2px rgba(255,255,255,0.3);
  border: 2px solid rgba(255,255,255,0.5);
}

.bs-location-area {
  margin-bottom: 16px;
}

.bs-location-label-text {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 10px;
  display: block;
  font-weight: 500;
}

.bs-location-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.bs-location-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-location-pill-label {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-location-pill-value {
  font-size: 12px;
  color: var(--text-primary);
  font-weight: 600;
}

.bs-action-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
  background: var(--card-bg);
  flex-shrink: 0;
  box-shadow: 0 -4px 20px var(--shadow-dark);
  border-top: 1px solid rgba(255, 255, 255, 0.5);
}

.bs-edit-btn {
  flex: 1;
  height: 44px;
  border-radius: 16px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 4px 4px 10px var(--shadow-dark), -3px -3px 10px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-edit-btn:active {
  transform: scale(0.97);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-edit-icon {
  font-size: 14px;
  color: var(--text-primary);
}

.bs-edit-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.bs-delete-btn {
  flex: 1;
  height: 44px;
  border-radius: 16px;
  background: linear-gradient(135deg, var(--accent-warm), var(--accent-coral));
  box-shadow: 3px 3px 10px rgba(184, 104, 96, 0.3), -2px -2px 6px rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.bs-delete-btn:active {
  transform: scale(0.97);
  box-shadow: inset 3px 3px 8px rgba(150, 80, 70, 0.4), inset -2px -2px 6px rgba(255,255,255,0.2);
}

.bs-delete-icon {
  font-size: 14px;
  color: #FFFFFF;
}

.bs-delete-text {
  font-size: 14px;
  font-weight: 600;
  color: #FFFFFF;
}
