<view class="container clothes-page" data-theme="{{__theme}}">
  <view class="safe-top px-4 pb-2" style="padding-top: 64px;">
    <text class="text-heading mb-3 block" style="color: var(--text-primary);">我的衣物</text>
    <view class="search-bar flex items-center px-3 py-2 rounded-xl">
      <text style="color: var(--text-muted); font-size: 14px; margin-right: 6px;">🔍</text>
      <input class="flex-1 text-body" style="color: var(--text-primary);" placeholder="搜索衣物..." value="{{searchQuery}}" bindinput="onSearch" />
      <view class="fav-filter-btn {{showFavoritesOnly ? 'fav-filter-active' : ''}}" bindtap="toggleFavoritesFilter">
        <text style="font-size: 20px;">{{showFavoritesOnly ? '★' : '☆'}}</text>
      </view>
    </view>
  </view>

  <!-- Left Sidebar Drawer -->
  <view class="sidebar-drawer {{sidebarOpen ? 'sidebar-open' : ''}}" style="transform: {{sidebarOpen ? 'translateX(0)' : 'translateX(-170px)'}}; opacity: {{sidebarOpen ? 1 : 0}};">
    <view class="sidebar-inner">
      <text class="sidebar-title">分类</text>
      <view wx:for="{{categories}}" wx:key="*this" bindtap="selectCategory" data-cat="{{item}}" class="sidebar-cat {{activeCategory === item ? 'sidebar-cat-active' : ''}}">
        <text class="cat-name">{{item}}</text>
        <text wx:if="{{item !== '全部' && expandedCategory === item}}" class="cat-arrow">▼</text>
        <text wx:elif="{{item !== '全部'}}" class="cat-arrow">▶</text>
      </view>
    </view>
    <!-- 二级分类面板 -->
    <view wx:if="{{expandedCategory && expandedCategory !== '全部'}}" class="subcat-panel" style="transform: {{sidebarOpen ? 'translateX(0)' : 'translateX(-20px)'}}; opacity: {{sidebarOpen ? 1 : 0}};">
      <text class="subcat-panel-title">{{expandedCategory}}</text>
      <view wx:for="{{CATEGORY_CONFIG[expandedCategory].subCategories}}" wx:key="*this" bindtap="selectSubCategory" data-sub="{{item}}" class="subcat-panel-item {{activeSubCategory === item ? 'subcat-panel-active' : ''}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- Sidebar Handle -->
  <view wx:if="{{!sidebarOpen}}" class="sidebar-handle" bindtap="toggleSidebar">
    <view class="handle-icon">
      <view class="handle-line"></view>
      <view class="handle-line"></view>
      <view class="handle-line"></view>
    </view>
    <text class="handle-label">分类</text>
  </view>

  <!-- Sidebar Overlay - 点击关闭侧边栏和二级分类 -->
  <view wx:if="{{sidebarOpen}}" class="sidebar-overlay-full" bindtap="closeSidebar"></view>

  <!-- Empty State -->
  <view wx:if="{{masonryLeft.length === 0 && masonryRight.length === 0}}" class="flex flex-col items-center justify-center py-20">
    <text style="font-size: 28px; color: var(--accent); margin-bottom: 8px;"></text>
    <text class="text-body" style="color: var(--text-muted);">暂无衣物</text>
  </view>

  <!-- Masonry Grid -->
  <view wx:else class="masonry px-4 mt-3">
    <view class="masonry-col">
      <view wx:for="{{masonryLeft}}" wx:key="id" class="masonry-item" bindtap="showDetail" data-id="{{item.id}}">
        <image class="masonry-img" src="{{item.image}}" mode="widthFix" />
        <view class="p-2">
          <text class="text-12px font-medium block truncate">{{item.name}}</text>
          <text class="text-10px" style="color: var(--text-muted);">{{item.category}} · {{item.style}}</text>
        </view>
      </view>
    </view>
    <view class="masonry-col">
      <view wx:for="{{masonryRight}}" wx:key="id" class="masonry-item" bindtap="showDetail" data-id="{{item.id}}">
        <image class="masonry-img" src="{{item.image}}" mode="widthFix" />
        <view class="p-2">
          <text class="text-12px font-medium block truncate">{{item.name}}</text>
          <text class="text-10px" style="color: var(--text-muted);">{{item.category}} · {{item.style}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Detail Bottom Sheet -->
  <view wx:if="{{showDetail}}" class="sheet-overlay" bindtap="hideDetail">
    <view class="sheet-panel" catchtap="preventBubble">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">衣物详情</text>
        <view class="sheet-header-actions">
          <view bindtap="toggleFavorite" class="sheet-fav-btn">
            <text style="color: {{detailItem.favorite ? '#E8927C' : '#B5ADA4'}}; font-size: 18px;">{{detailItem.favorite ? '★' : '☆'}}</text>
          </view>
          <view bindtap="hideDetail" class="sheet-close">
            <text style="color: var(--text-muted); font-size: 18px; line-height: 1;">×</text>
          </view>
        </view>
      </view>

      <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
        <!-- Photo -->
        <view class="detail-photo-wrap" wx:if="{{detailItem}}">
          <view class="detail-photo-carousel">
            <image class="detail-photo-img" src="{{detailItem.image}}" mode="aspectFill" />
          </view>
        </view>

        <!-- Info -->
        <view class="detail-info-area" wx:if="{{detailItem}}">
          <text class="detail-title">{{detailItem.name}}</text>
          <view class="detail-meta">
            <text class="detail-category">{{detailItem.category}}</text>
            <text wx:if="{{detailItem.subCategory}}" class="detail-subcategory">{{detailItem.subCategory}}</text>
            <text class="detail-style">{{detailItem.style}}</text>
          </view>
        </view>

        <!-- Tags -->
        <view class="detail-tags-area" wx:if="{{detailItem && detailItem.seasons && detailItem.seasons.length > 0}}">
          <text class="detail-section-label">适用季节</text>
          <view class="detail-tags-row">
            <view class="detail-tag-pill" wx:for="{{detailItem.seasons}}" wx:key="*this">
              <text class="detail-tag-text">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- Colors -->
        <view class="detail-colors-area" wx:if="{{detailItem && detailItem.colors && detailItem.colors.length > 0}}">
          <text class="detail-section-label">颜色</text>
          <view class="detail-colors-row">
            <view wx:for="{{detailItem.colors}}" wx:key="*this" class="detail-color-dot" style="background: {{item}};"></view>
          </view>
        </view>

        <!-- Location -->
        <view class="detail-location-area" wx:if="{{detailItem}}">
          <text class="detail-section-label">位置信息</text>
          <view class="detail-location-pills">
            <view class="detail-location-pill">
              <text class="detail-location-pill-label">衣柜</text>
              <text class="detail-location-pill-value">{{detailWardrobeName}}</text>
            </view>
            <view class="detail-location-pill">
              <text class="detail-location-pill-label">分区</text>
              <text class="detail-location-pill-value">{{detailZoneName}}</text>
            </view>
          </view>
        </view>

        <view style="height: 4px;"></view>
      </scroll-view>

      <!-- Bottom Actions -->
      <view class="sheet-footer detail-footer">
        <view class="detail-edit-btn" bindtap="goToEdit">
          <text class="detail-edit-icon">✎</text>
          <text class="detail-edit-text">编辑</text>
        </view>
        <view class="detail-delete-btn" bindtap="deleteItem">
          <text class="detail-delete-icon">🗑</text>
          <text class="detail-delete-text">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>
