.detail-page { min-height: 100vh; padding-bottom: calc(24px + env(safe-area-inset-bottom)); background: var(--bg); }

/* ===== Safe Area Header ===== */
.safe-header {
  padding-top: 54px;
  background: var(--bg);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 50px;
  padding: 0 16px;
  margin: 0 12px;
  background: var(--card-bg);
  border-radius: 18px;
  box-shadow: 6px 6px 16px var(--shadow-dark), -4px -4px 16px var(--shadow-light);
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  min-width: 60px;
}

.back-icon {
  width: 18px;
  height: 18px;
}

.back-text {
  font-size: 13px;
  color: var(--text-muted);
}

.header-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
  text-align: center;
  flex: 1;
}

.header-placeholder {
  min-width: 60px;
}

/* ===== Empty State ===== */
.empty-state {
  margin: 24px 16px;
  padding: 56px 24px;
  border-radius: 18px;
  background: var(--bg);
  box-shadow: inset 4px 4px 12px var(--shadow-inset-dark), inset -4px -4px 12px var(--shadow-inset-light);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-state-icon {
  width: 64px;
  height: 64px;
  border-radius: 18px;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  box-shadow: 4px 4px 12px var(--shadow-dark), -4px -4px 12px var(--shadow-light);
}

.empty-state-img {
  width: 28px;
  height: 28px;
}

.empty-state-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
  line-height: 1.4;
}

.empty-state-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
}

.add-btn { display: flex; align-items: center; justify-content: center; padding: 16px; border-radius: 18px; border: 2px dashed var(--border); background: var(--card-bg); box-shadow: inset 3px 3px 8px var(--shadow-inset-dark), inset -3px -3px 8px var(--shadow-inset-light); }
.zone-item { padding: 14px; display: flex; align-items: center; justify-content: space-between; }

.zone-icon-box {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.zone-icon {
  width: 20px;
  height: 20px;
}
.mb-3 { margin-bottom: 12px; }
.bottom-sheet { background: var(--card-bg, var(--bg)); border-radius: 28px; padding: 20px 16px 40px 16px; position: relative; z-index: 10; width: 92vw; max-width: 560px; margin: 0 auto calc(24px + env(safe-area-inset-bottom)) auto; border: 1px solid rgba(255, 255, 255, 0.5); box-shadow: 0 -12px 48px var(--shadow-dark), 0 -4px 16px var(--shadow-dark), 0 -1px 4px var(--shadow-dark), inset 0 1px 0 rgba(255, 255, 255, 0.6); }
.form-input { width: 100%; height: 44px; padding: 0 14px; border-radius: 10px; background: var(--bg); box-shadow: inset 3px 3px 8px var(--shadow-inset-dark), inset -3px -3px 8px var(--shadow-inset-light); font-size: 14px; color: var(--text-primary); box-sizing: border-box; line-height: 44px; }
.zone-type-grid { display: flex; flex-wrap: wrap; gap: 10px; }
.zone-type-pill { padding: 8px 16px; border-radius: 9999px; font-size: 12px; color: var(--text-muted); background: var(--bg); box-shadow: 2px 2px 6px var(--shadow-dark), -2px -2px 6px var(--shadow-light); white-space: nowrap; }
.zone-type-active { color: var(--accent); background: var(--accent-soft); box-shadow: 3px 3px 8px var(--shadow-dark), -3px -3px 8px var(--shadow-light); }
.transform { transform: translateX(-50%); }
.absolute { position: absolute; }
.left-1_2 { left: 50%; }

/* Font size utilities */
.text-13px { font-size: 13px; }
.text-11px { font-size: 11px; }
.text-10px { font-size: 10px; }

/* ===== Confirm Button ===== */
.btn-confirm {
  height: 48px;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-coral) 100%);
  color: white;
  font-size: 15px;
  font-weight: 600;
  border: none;
  box-shadow: 0 4px 14px var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-confirm::after {
  border: none;
}

.btn-confirm:active {
  transform: scale(0.96);
  box-shadow: 0 2px 8px var(--accent-soft);
}

/* ===== Section Header (for unassigned items) ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 8px;
}

.section-dot {
  width: 4px;
  height: 16px;
  border-radius: 2px;
  background: var(--accent);
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.section-count {
  font-size: 12px;
  color: var(--text-muted);
}

/* ===== Masonry Grid (clothes card style) ===== */
.masonry {
  display: flex;
  gap: 12px;
}

.masonry-col {
  flex: 1;
}

.masonry-item {
  border-radius: 14px;
  overflow: hidden;
  background: var(--card-bg);
  box-shadow: 4px 4px 12px var(--shadow-dark), -3px -3px 12px var(--shadow-light);
  margin-bottom: 12px;
}

.masonry-img {
  width: 100%;
  display: block;
}

.text-12px {
  font-size: 12px;
}

.p-2 {
  padding: 8px;
}

/* ===== Bottom Sheet ===== */
.bs-overlay-item {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  animation: bsFadeIn 300ms ease-out;
}

@keyframes bsFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.bs-sheet {
  background: var(--card-bg);
  border-radius: 28px;
  border: 1px solid rgba(255, 255, 255, 0.5);
  height: 68vh;
  max-height: 68vh;
  width: 88vw;
  max-width: 520px;
  margin: 0 auto calc(24px + env(safe-area-inset-bottom)) auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  box-shadow:
    0 -12px 48px var(--shadow-dark),
    0 -4px 16px var(--shadow-dark),
    0 -1px 4px var(--shadow-dark),
    inset 0 1px 0 rgba(255, 255, 255, 0.6);
  transform: translateY(100%);
  transition: transform 400ms cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.bs-sheet-visible {
  transform: translateY(0);
}

.bs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px 12px;
  flex-shrink: 0;
}

.bs-header-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 6px 6px 12px var(--shadow-dark), -6px -6px 12px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bs-header-btn:active {
  transform: scale(0.95);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-header-btn-icon {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1;
  font-weight: 500;
}

.bs-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 16px;
  min-height: 0;
}

.bs-photo-wrap {
  position: relative;
  margin-bottom: 16px;
}

.bs-photo-carousel {
  width: 100%;
  margin: 0;
  height: calc(88vw * 9 / 16);
  max-height: calc(520px * 9 / 16);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 4px 4px 12px var(--shadow-dark), -2px -2px 8px var(--shadow-light);
}

.bs-photo-img {
  width: 100%;
  height: calc(88vw * 9 / 16);
  max-height: calc(520px * 9 / 16);
  display: block;
  object-fit: cover;
}

.bs-info-area {
  margin-bottom: 12px;
}

.bs-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.2px;
}

.bs-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
  display: block;
}

.bs-tags-area {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.bs-tag-pill {
  padding: 5px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-tag-text {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-colors-area {
  margin-bottom: 16px;
}

.bs-colors-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: block;
  font-weight: 500;
}

.bs-colors-row {
  display: flex;
  gap: 10px;
}

.bs-color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  box-shadow: 3px 3px 8px rgba(0,0,0,0.15), -2px -2px 6px rgba(255,255,255,0.6), inset 0 1px 2px rgba(255,255,255,0.3);
  border: 2px solid rgba(255,255,255,0.5);
}

.bs-location-area {
  margin-bottom: 16px;
}

.bs-location-label-text {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 10px;
  display: block;
  font-weight: 500;
}

.bs-location-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.bs-location-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: 9999px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 3px 3px 8px var(--shadow-dark), -2px -2px 6px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-location-pill-label {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
}

.bs-location-pill-value {
  font-size: 12px;
  color: var(--text-primary);
  font-weight: 600;
}

.bs-action-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
  background: var(--card-bg);
  flex-shrink: 0;
  box-shadow: 0 -4px 20px var(--shadow-dark);
  border-top: 1px solid rgba(255, 255, 255, 0.5);
}

.bs-edit-btn {
  flex: 1;
  height: 46px;
  border-radius: 16px;
  background: linear-gradient(145deg, var(--card-bg), var(--bg));
  box-shadow: 4px 4px 10px var(--shadow-dark), -3px -3px 10px var(--shadow-light), inset 0 1px 0 rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.bs-edit-btn:active {
  transform: scale(0.97);
  box-shadow: inset 3px 3px 6px var(--shadow-inset-dark), inset -3px -3px 6px var(--shadow-inset-light);
}

.bs-edit-icon {
  font-size: 14px;
  color: var(--text-primary);
}

.bs-edit-text {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.bs-delete-btn {
  flex: 1;
  height: 46px;
  border-radius: 16px;
  background: linear-gradient(135deg, var(--accent-warm), var(--accent-coral));
  box-shadow: 3px 3px 10px rgba(184, 104, 96, 0.3), -2px -2px 6px rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.bs-delete-btn:active {
  transform: scale(0.97);
  box-shadow: inset 3px 3px 8px rgba(150, 80, 70, 0.4), inset -2px -2px 6px rgba(255,255,255,0.2);
}

.bs-delete-icon {
  font-size: 14px;
  color: #FFFFFF;
}

.bs-delete-text {
  font-size: 14px;
  font-weight: 600;
  color: #FFFFFF;
}
