.detail-page { min-height: 100vh; padding-bottom: calc(24px + env(safe-area-inset-bottom)); background: var(--bg); }

/* ===== Safe Area Header ===== */
.safe-header {
  padding-top: 54px;
  background: var(--bg);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 50px;
  padding: 0 16px;
  margin: 0 12px;
  background: var(--card-bg);
  border-radius: 18px;
  box-shadow: 6px 6px 16px var(--shadow-dark), -4px -4px 16px var(--shadow-light);
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  min-width: 60px;
}

.back-icon {
  width: 18px;
  height: 18px;
}

.back-text {
  font-size: 13px;
  color: var(--text-muted);
}

.header-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
  text-align: center;
  flex: 1;
}

.header-placeholder {
  min-width: 60px;
}

/* ===== Empty State ===== */
.empty-state {
  margin: 24px 16px;
  padding: 56px 24px;
  border-radius: 18px;
  background: var(--bg);
  box-shadow: inset 4px 4px 12px var(--shadow-inset-dark), inset -4px -4px 12px var(--shadow-inset-light);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-state-icon {
  width: 64px;
  height: 64px;
  border-radius: 18px;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  box-shadow: 4px 4px 12px var(--shadow-dark), -4px -4px 12px var(--shadow-light);
}

.empty-state-img {
  width: 28px;
  height: 28px;
}

.empty-state-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
  line-height: 1.4;
}

.empty-state-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
}

.add-btn { display: flex; align-items: center; justify-content: center; padding: 16px; border-radius: 18px; border: 2px dashed var(--border); background: var(--card-bg); box-shadow: inset 3px 3px 8px var(--shadow-inset-dark), inset -3px -3px 8px var(--shadow-inset-light); }
.zone-item { padding: 14px; display: flex; align-items: center; justify-content: space-between; }

.zone-icon-box {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: var(--accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.zone-icon {
  width: 20px;
  height: 20px;
}
.mb-3 { margin-bottom: 12px; }
.delete-zone { padding: 4px 8px; border-radius: 6px; background: rgba(193,124,116,0.1); }
.bottom-sheet { background: var(--card-bg, var(--bg)); border-radius: 28px; padding: 20px 16px 40px 16px; position: relative; z-index: 10; width: 92vw; max-width: 560px; margin: 0 auto calc(24px + env(safe-area-inset-bottom)) auto; border: 1px solid rgba(255, 255, 255, 0.5); box-shadow: 0 -12px 48px var(--shadow-dark), 0 -4px 16px var(--shadow-dark), 0 -1px 4px var(--shadow-dark), inset 0 1px 0 rgba(255, 255, 255, 0.6); }
.form-input { width: 100%; height: 44px; padding: 0 14px; border-radius: 10px; background: var(--bg); box-shadow: inset 3px 3px 8px var(--shadow-inset-dark), inset -3px -3px 8px var(--shadow-inset-light); font-size: 14px; color: var(--text-primary); box-sizing: border-box; line-height: 44px; }
.zone-type-grid { display: flex; flex-wrap: wrap; gap: 10px; }
.zone-type-pill { padding: 8px 16px; border-radius: 9999px; font-size: 12px; color: var(--text-muted); background: var(--bg); box-shadow: 2px 2px 6px var(--shadow-dark), -2px -2px 6px var(--shadow-light); white-space: nowrap; }
.zone-type-active { color: var(--accent); background: var(--accent-soft); box-shadow: 3px 3px 8px var(--shadow-dark), -3px -3px 8px var(--shadow-light); }
.transform { transform: translateX(-50%); }
.absolute { position: absolute; }
.left-1_2 { left: 50%; }

/* Font size utilities */
.text-13px { font-size: 13px; }
.text-11px { font-size: 11px; }
.text-10px { font-size: 10px; }
