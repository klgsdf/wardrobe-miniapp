/* ===== 底部导航栏容器 ===== */
.tab-bar-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  height: auto;
  pointer-events: none;
}

/* 顶部渐变分界线 - 营造与内容的视觉分界 */
.tab-bar-divider {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(
    to right,
    transparent 0%,
    rgba(160, 148, 134, 0.2) 20%,
    rgba(160, 148, 134, 0.35) 50%,
    rgba(160, 148, 134, 0.2) 80%,
    transparent 100%
  );
  z-index: 2;
}

/* 底部安全区占位 */
.tab-bar-safe-block {
  height: calc(56px + env(safe-area-inset-bottom));
}

/* ===== 玻璃拟态背景层 ===== */
.tab-bar-glass {
  position: absolute;
  inset: 0;
  background: rgba(245, 241, 232, 0.72);
  backdrop-filter: blur(24px) saturate(1.3);
  -webkit-backdrop-filter: blur(24px) saturate(1.3);
  /* 内阴影营造凹陷感，外阴影营造浮起感 */
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.6),
    inset 0 2px 4px rgba(255, 255, 255, 0.3),
    0 -4px 20px rgba(160, 148, 134, 0.12),
    0 -1px 3px rgba(160, 148, 134, 0.08);
  z-index: 1;
}

/* ===== 导航内容区 ===== */
.tab-bar-content {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 6px 12px 8px;
  pointer-events: auto;
}

/* 导航按钮组 */
.tab-bar-group {
  display: flex;
  align-items: center;
  justify-content: space-around;
  flex: 1;
  gap: 4px;
}

/* ===== 单个导航按钮 ===== */
.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  padding: 4px 0;
  min-width: 56px;
  position: relative;
  transition: all 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 图标容器 */
.tab-bar-icon-wrap {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  transition: all 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

.tab-bar-icon {
  width: 22px;
  height: 22px;
  opacity: 0.55;
  transition: all 250ms ease;
  filter: grayscale(0.3);
}

/* 文字 */
.tab-bar-text {
  font-size: 10px;
  font-weight: 400;
  color: var(--text-muted);
  transition: all 250ms ease;
  letter-spacing: 0.02em;
}

/* ===== 激活状态 ===== */
.tab-bar-item-active {
  transform: translateY(-3px);
}

.tab-bar-item-active .tab-bar-icon-wrap {
  background: linear-gradient(145deg, rgba(255,255,255,0.9), rgba(255,255,255,0.5));
  box-shadow:
    0 4px 12px rgba(176, 137, 104, 0.2),
    0 0 0 1px rgba(176, 137, 104, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.tab-bar-item-active .tab-bar-icon {
  opacity: 1;
  filter: grayscale(0) drop-shadow(0 1px 2px rgba(176, 137, 104, 0.25));
}

.tab-bar-text-active {
  color: var(--accent);
  font-weight: 600;
  text-shadow: 0 1px 2px rgba(176, 137, 104, 0.15);
}

/* 激活指示点 */
.tab-bar-indicator {
  position: absolute;
  bottom: -2px;
  left: 50%;
  transform: translateX(-50%);
  width: 18px;
  height: 3px;
  border-radius: 9999px;
  background: linear-gradient(90deg, var(--accent), var(--accent-warm));
  box-shadow: 0 0 8px rgba(176, 137, 104, 0.35);
  animation: indicatorIn 250ms ease-out;
}

@keyframes indicatorIn {
  from { opacity: 0; transform: translateX(-50%) scaleX(0.3); }
  to { opacity: 1; transform: translateX(-50%) scaleX(1); }
}

/* ===== 中央 ADD 按钮 ===== */
.tab-bar-add-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10px;
  margin-top: -16px;
}

.tab-bar-add-btn {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  /* 玻璃拟态基底 */
  background: linear-gradient(145deg, rgba(60, 60, 65, 0.85), rgba(30, 30, 35, 0.9));
  /* 多层阴影营造立体感 */
  box-shadow:
    0 6px 20px rgba(0, 0, 0, 0.25),
    0 2px 6px rgba(0, 0, 0, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.12),
    inset 0 -1px 0 rgba(0, 0, 0, 0.2);
  transition: all 200ms ease;
}

/* ADD 按钮毛玻璃效果 - 伪元素 */
.tab-bar-add-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.15) 0%, transparent 60%);
  pointer-events: none;
}

/* ADD 按钮微亮描边 */
.tab-bar-add-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

.tab-bar-add-btn:active {
  transform: scale(0.92);
  box-shadow:
    0 3px 10px rgba(0, 0, 0, 0.2),
    0 1px 3px rgba(0, 0, 0, 0.12),
    inset 0 2px 4px rgba(0, 0, 0, 0.15);
}

.tab-bar-add-icon {
  font-size: 24px;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
  position: relative;
  z-index: 2;
}

/* ===== 主题适配 ===== */

/* --- mint-latte --- */
.tab-bar-wrap[data-theme="mint-latte"] .tab-bar-glass {
  background: rgba(255, 251, 245, 0.75);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.7),
    inset 0 2px 4px rgba(255, 255, 255, 0.25),
    0 -4px 20px rgba(180, 165, 148, 0.1),
    0 -1px 3px rgba(180, 165, 148, 0.06);
}

.tab-bar-wrap[data-theme="mint-latte"] .tab-bar-divider {
  background: linear-gradient(
    to right,
    transparent 0%,
    rgba(150, 140, 130, 0.18) 20%,
    rgba(150, 140, 130, 0.3) 50%,
    rgba(150, 140, 130, 0.18) 80%,
    transparent 100%
  );
}

.tab-bar-wrap[data-theme="mint-latte"] .tab-bar-item-active .tab-bar-icon-wrap {
  box-shadow:
    0 4px 12px rgba(125, 185, 168, 0.2),
    0 0 0 1px rgba(125, 185, 168, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.tab-bar-wrap[data-theme="mint-latte"] .tab-bar-item-active .tab-bar-icon {
  filter: grayscale(0) drop-shadow(0 1px 2px rgba(125, 185, 168, 0.25));
}

.tab-bar-wrap[data-theme="mint-latte"] .tab-bar-text-active {
  text-shadow: 0 1px 2px rgba(125, 185, 168, 0.15);
}

.tab-bar-wrap[data-theme="mint-latte"] .tab-bar-indicator {
  background: linear-gradient(90deg, var(--accent), var(--accent-warm));
  box-shadow: 0 0 8px rgba(125, 185, 168, 0.35);
}

